@model IEnumerable<LibraryManagementSystem.Models.ViewModel.BorrowingViewModel>

@{
    ViewBag.Title = "Borrowing Transactions";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0 rounded-4" style="background: rgba(255, 255, 255, 0.45); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.25);">
        <div class="card-header border-0 rounded-top-4" style="background-color: var(--primary-rose) !important; color: var(--text-dark); padding: 20px;">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 w-100">
                <div>
                    <h4 class="mb-0" style="font-family: 'Playfair Display', serif; font-weight: 700; color: var(--text-dark) !important;">Borrowing Transactions</h4>
                    <p class="mb-0 text-muted" style="font-size: 13px; color: var(--text-dark) !important; opacity: 0.85;">Librarian panel to manage borrowing requests, verify returns, and collect fine payments.</p>
                </div>

                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <!-- Right Corner Search Capsule -->
                    <form action="@Url.Action("Index", "MVCBorrowings")" method="get" class="d-inline-block m-0">
                        <div class="position-relative" style="width: 260px;">
                            <input type="text" name="search" class="form-control rounded-pill border-0 ps-3 pe-5" placeholder="Search book, borrower..." value="@ViewBag.Search" style="font-size: 13px; height: 32px; background-color: rgba(255, 255, 255, 0.85); color: var(--text-dark) !important; box-shadow: none; border-radius: 50rem !important;" />
                            @if (!string.IsNullOrWhiteSpace(ViewBag.Search))
                            {
                                <a href="@Url.Action("Index", "MVCBorrowings")" class="position-absolute text-muted" style="right: 36px; top: 50%; transform: translateY(-50%); font-size: 12px; text-decoration: none;">
                                    <i class="bi bi-x-circle-fill" style="color: var(--text-muted);"></i>
                                </a>
                            }
                            <button type="submit" class="btn position-absolute p-0 border-0 bg-transparent text-muted" style="right: 12px; top: 50%; transform: translateY(-50%); display: flex; align-items: center;">
                                <i class="bi bi-search" style="color: var(--text-muted); font-size: 14px;"></i>
                            </button>
                        </div>
                    </form>

                    <a href="@Url.Action("Librarian", "DashboardMvc")" class="btn btn-sm btn-light rounded-pill px-3" style="color: var(--primary-rose); font-weight: 600; height: 32px; display: inline-flex; align-items: center; border-radius: 50rem !important;">
                        <i class="bi bi-speedometer2 me-1"></i> Back to Dashboard
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body p-4">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success rounded-3">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger rounded-3">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                </div>
            }

            <div class="table-responsive rounded-4 border border-light">
                <table class="table table-hover align-middle mb-0 paginated-table" data-page-size="5">
                    <thead style="background-color: rgba(201, 122, 126, 0.1); border-bottom: 2px solid rgba(201, 122, 126, 0.15);">
                        <tr>
                            <th class="ps-3" style="color: #4A2E35;">No</th>
                            <th style="color: #4A2E35;">Member</th>
                            <th style="color: #4A2E35;">Book</th>
                            <th style="color: #4A2E35;">Req Date</th>
                            <th style="color: #4A2E35;">Borrow Date</th>
                            <th style="color: #4A2E35;">Due Date</th>
                            <th style="color: #4A2E35;">Return Date</th>
                            <th style="color: #4A2E35;">Status</th>
                            <th style="color: #4A2E35;">Fine</th>
                            <th style="color: #4A2E35;">Fine Status</th>
                            <th class="pe-3 text-end" style="color: #4A2E35;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            var no = 1;
                        }

                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3" style="font-weight: 600;">@no</td>
                                <td style="font-weight: 600; color: #4A2E35;">@item.MemberName</td>
                                <td>@item.BookTitle</td>
                                <td>@item.RequestDate.ToString("dd-MM-yyyy")</td>

                                <td>
                                    @(item.BorrowDate == null ? "-" : item.BorrowDate.Value.ToString("dd-MM-yyyy"))
                                </td>

                                <td>
                                    @(item.DueDate == null ? "-" : item.DueDate.Value.ToString("dd-MM-yyyy"))
                                </td>

                                <td>
                                    @(item.ReturnDate == null ? "-" : item.ReturnDate.Value.ToString("dd-MM-yyyy"))
                                </td>

                                <td>
                                    @if (item.Status == "Requested")
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill px-3 py-1">Requested</span>
                                    }
                                    else if (item.Status == "Borrowed")
                                    {
                                        <span class="badge bg-primary rounded-pill px-3 py-1">Borrowed</span>
                                    }
                                    else if (item.Status == "Returned")
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-1">Returned</span>
                                    }
                                    else if (item.Status == "Rejected")
                                    {
                                        <span class="badge bg-danger rounded-pill px-3 py-1">Rejected</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3 py-1">@item.Status</span>
                                    }
                                </td>

                                <td>
                                    @if (item.FineAmount != null && item.FineAmount > 0)
                                    {
                                        <span class="badge bg-danger rounded-pill px-3 py-1">
                                            Rp @item.FineAmount.Value.ToString("N0")
                                        </span>

                                        if (item.LateDays != null && item.LateDays > 0)
                                        {
                                            <br />
                                            <small class="text-muted" style="font-size: 11px;">
                                                Late by @item.LateDays Days
                                            </small>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>

                                <td>
                                    @if (string.IsNullOrWhiteSpace(item.FineStatus))
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                    else if (item.FineStatus == "Paid")
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-1">Paid</span>
                                    }
                                    else if (item.FineStatus == "Unpaid")
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill px-3 py-1">Unpaid</span>
                                    }
                                    else if (item.FineStatus == "None")
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3 py-1">None</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3 py-1">@item.FineStatus</span>
                                    }
                                </td>

                                <td class="pe-3 text-end">
                                    <div class="d-inline-flex gap-1">
                                        @if (item.Status == "Requested")
                                        {
                                            <a href="@Url.Action("Approve", "MVCBorrowings", new { id = item.Id })"
                                               class="btn btn-sm btn-success rounded-pill px-3"
                                               onclick="return confirm('Approve this borrowing request?');">
                                                <i class="bi bi-check-lg"></i> Approve
                                            </a>

                                            <a href="@Url.Action("Reject", "MVCBorrowings", new { id = item.Id })"
                                               class="btn btn-sm btn-danger rounded-pill px-3"
                                               onclick="return confirm('Reject this borrowing request?');">
                                                <i class="bi bi-x-lg"></i> Reject
                                            </a>
                                        }
                                        else if (item.Status == "Borrowed")
                                        {
                                            <a href="@Url.Action("ReturnConfirm", "MVCBorrowings", new { id = item.Id })"
                                               class="btn btn-sm btn-primary rounded-pill px-3">
                                                <i class="bi bi-box-arrow-in-left"></i> Return
                                            </a>

                                            <a href="@Url.Action("SimulateFine", "MVCBorrowings", new { id = item.Id })"
                                               class="btn btn-sm btn-outline-danger rounded-pill px-3 ms-1"
                                               onclick="return confirm('Simulate a late return with a fine for testing?');">
                                                <i class="bi bi-bug"></i> Test Fine
                                            </a>
                                        }
                                        else if (item.Status == "Returned" && item.FineAmount != null && item.FineAmount > 0 && item.FineStatus == "Unpaid")
                                        {
                                            <a href="@Url.Action("PayFineConfirm", "MVCBorrowings", new { id = item.Id })"
                                               class="btn btn-sm btn-success rounded-pill px-3">
                                                <i class="bi bi-qr-code"></i> Pay Fine
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted fs-7">No Action</span>
                                        }
                                    </div>
                                </td>
                            </tr>

                            no++;
                        }

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="11" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox-fill d-block fs-3 mb-2 opacity-50"></i>
                                    No borrowing records found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>
