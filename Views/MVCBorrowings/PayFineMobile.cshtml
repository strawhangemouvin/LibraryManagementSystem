@model LibraryManagementSystem.Models.Entity.Borrowing

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Moon Pay - QRIS checkout</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    
    <style>
        :root {
            --primary-rose: #C97A7E;
            --dark-rose: #4A2E35;
            --light-rose: #FAF5F6;
            --success-green: #28a745;
            --bg-gradient: linear-gradient(135deg, #FAF5F6 0%, #F3E7E8 100%);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-gradient);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            color: #333;
            margin: 0;
            padding: 0;
        }

        .mobile-shell {
            width: 100%;
            max-width: 412px; /* Standard mobile phone width */
            min-height: 100vh;
            background: #fafafa;
            box-shadow: 0 10px 40px rgba(74, 46, 53, 0.12);
            position: relative;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        @@media (min-width: 576px) {
            .mobile-shell {
                min-height: 780px;
                border-radius: 36px;
                border: 8px solid #2c2c2e;
                margin: 20px 0;
            }
        }

        /* App Header */
        .app-header {
            background: linear-gradient(135deg, var(--dark-rose) 0%, #301A1E 100%);
            color: white;
            padding: 20px 20px 15px 20px;
            border-bottom-left-radius: 24px;
            border-bottom-right-radius: 24px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        }

        .brand-title {
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            font-size: 18px;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .brand-subtitle {
            font-size: 11px;
            opacity: 0.8;
            margin-top: 2px;
        }

        /* App Body */
        .app-body {
            flex: 1;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            background: #FAF5F6;
        }

        /* Premium Cards */
        .pay-card {
            background: white;
            border-radius: 20px;
            border: 1px solid rgba(201, 122, 126, 0.12);
            box-shadow: 0 4px 20px rgba(74, 46, 53, 0.03);
            padding: 20px;
            margin-bottom: 20px;
        }

        .merchant-badge {
            display: inline-block;
            background: rgba(201, 122, 126, 0.1);
            color: var(--dark-rose);
            font-weight: 600;
            font-size: 11px;
            padding: 4px 12px;
            border-radius: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
        }

        .amount-display {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            color: var(--dark-rose);
            font-size: 32px;
            margin: 8px 0;
        }

        /* Details list */
        .detail-row {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            padding: 8px 0;
            border-bottom: 1px solid rgba(0,0,0,0.03);
        }

        .detail-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .detail-label {
            color: #7E6569;
        }

        .detail-val {
            font-weight: 600;
            color: #333;
        }

        /* PIN Keypad CSS */
        .pin-dot {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            border: 2px solid var(--primary-rose);
            background: transparent;
            transition: all 0.15s ease;
        }

        .pin-dot.filled {
            background: var(--primary-rose);
            transform: scale(1.2);
        }

        .btn-pin {
            width: 100%;
            height: 52px;
            border-radius: 16px;
            background: white;
            border: 1px solid rgba(0,0,0,0.04);
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            font-size: 20px;
            color: var(--dark-rose);
            box-shadow: 0 3px 6px rgba(0,0,0,0.015);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.1s ease;
        }

        .btn-pin:active {
            background: var(--primary-rose);
            color: white;
            border-color: var(--primary-rose);
            transform: scale(0.92);
        }

        /* Receipt Dashed Line */
        .receipt-divider {
            position: relative;
            height: 20px;
            border-top: 2px dashed rgba(201, 122, 126, 0.25);
            margin: 20px 0;
        }
        .receipt-divider::before,
        .receipt-divider::after {
            content: '';
            position: absolute;
            top: -11px;
            width: 20px;
            height: 20px;
            background: #FAF5F6;
            border-radius: 50%;
        }
        .receipt-divider::before { left: -31px; }
        .receipt-divider::after { right: -31px; }

        /* Success Pulse */
        .success-icon-container {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 68px;
            height: 68px;
            background: rgba(40, 167, 69, 0.1);
            color: var(--success-green);
            border-radius: 50%;
            font-size: 32px;
            animation: pulseGreen 1.5s infinite;
            margin: 10px auto;
        }

        @@keyframes pulseGreen {
            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(40, 167, 69, 0.4); }
            70% { transform: scale(1.06); box-shadow: 0 0 0 10px rgba(40, 167, 69, 0); }
            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(40, 167, 69, 0); }
        }

        /* Custom buttons */
        .btn-main {
            background: var(--primary-rose);
            color: white;
            border: none;
            font-weight: 700;
            padding: 12px 24px;
            border-radius: 30px;
            box-shadow: 0 4px 15px rgba(201, 122, 126, 0.3);
            transition: all 0.2s ease;
        }

        .btn-main:active {
            transform: scale(0.96);
            background: #b56b6f;
        }
        
        /* Fade In Animations */
        .fade-in-up {
            animation: fadeInUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

    <div class="mobile-shell">
        <!-- Header -->
        <div class="app-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="brand-title">
                        <i class="bi bi-wallet2"></i> Moon Pay
                    </div>
                    <div class="brand-subtitle">Simulated QRIS Checkout Platform</div>
                </div>
                <div>
                    <span class="badge bg-success rounded-pill px-2 py-1" style="font-size: 9px; letter-spacing: 0.5px;">SECURE SIMULATOR</span>
                </div>
            </div>
        </div>

        <!-- Body -->
        <div class="app-body">
            
            <!-- 1. SCREEN: CONFIRM PAYMENT -->
            <div id="screenConfirm" class="w-100 flex-grow-1 d-flex flex-column justify-content-between fade-in-up">
                <div>
                    <div class="text-center my-3">
                        <span class="merchant-badge"><i class="bi bi-shop me-1"></i> Library Merchant</span>
                        <h5 style="font-weight: 700; color: var(--dark-rose); margin-bottom: 2px;">Moon Books Library</h5>
                        <small class="text-muted" style="font-size: 12px;">Ref: MB-FINE-@Model.Id</small>
                    </div>

                    <div class="pay-card text-center">
                        <small class="text-uppercase text-muted" style="font-size: 10px; font-weight: 700; letter-spacing: 0.5px;">Total Fine Amount</small>
                        <div class="amount-display">Rp @((Model.FineAmount ?? 0).ToString("N0"))</div>
                        <div class="alert alert-warning py-2 px-3 mb-0 rounded-3 text-center" style="font-size: 11px; border: none; background: rgba(240, 173, 78, 0.1); color: #a97507;">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i> Simulated late return fee of <b>@(Model.LateDays ?? 0) days</b>
                        </div>
                    </div>

                    <div class="pay-card">
                        <h6 style="font-weight: 700; font-size: 13px; color: var(--dark-rose); margin-bottom: 12px;">Billing Details</h6>
                        <div class="detail-row">
                            <span class="detail-label">Book Title</span>
                            <span class="detail-val text-truncate" style="max-width: 180px;">@(Model.Book != null ? Model.Book.Title : "Book Fine")</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Member Code</span>
                            <span class="detail-val">@(Model.Member != null ? Model.Member.MemberCode : "-")</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Due Date</span>
                            <span class="detail-val">@(Model.DueDate == null ? "-" : Model.DueDate.Value.ToString("dd-MM-yyyy"))</span>
                        </div>
                    </div>
                </div>

                <div class="mb-2 text-center">
                    <p style="font-size: 11px; color: #8c8c8c; line-height: 1.4; margin-bottom: 15px;">
                        This is a simulated transaction. Clicking pay will immediately update the library screen to successful.
                    </p>
                    <button type="button" class="btn btn-main w-100 py-3 rounded-pill" onclick="goToPinScreen();">
                        <i class="bi bi-shield-check me-1"></i> Confirm &amp; Pay Fine
                    </button>
                </div>
            </div>

            <!-- 2. SCREEN: ENTER PIN -->
            <div id="screenPin" class="w-100 flex-grow-1 d-none flex-column justify-content-between fade-in-up">
                <div class="text-center mt-3">
                    <h5 style="font-weight: 700; color: var(--dark-rose); margin-bottom: 4px;">Enter Secure PIN</h5>
                    <p class="text-muted" style="font-size: 12px;">Please enter your 6-digit Moon Pay PIN</p>
                    
                    <!-- PIN Dots -->
                    <div class="d-flex justify-content-center gap-3 my-4">
                        <span class="pin-dot" id="dot1"></span>
                        <span class="pin-dot" id="dot2"></span>
                        <span class="pin-dot" id="dot3"></span>
                        <span class="pin-dot" id="dot4"></span>
                        <span class="pin-dot" id="dot5"></span>
                        <span class="pin-dot" id="dot6"></span>
                    </div>
                </div>

                <!-- Keypad -->
                <div class="w-100 px-2 mb-3">
                    <div class="row g-2 mb-2">
                        <div class="col-4"><button type="button" class="btn btn-pin" onclick="pressPinKey(1)">1</button></div>
                        <div class="col-4"><button type="button" class="btn btn-pin" onclick="pressPinKey(2)">2</button></div>
                        <div class="col-4"><button type="button" class="btn btn-pin" onclick="pressPinKey(3)">3</button></div>
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col-4"><button type="button" class="btn btn-pin" onclick="pressPinKey(4)">4</button></div>
                        <div class="col-4"><button type="button" class="btn btn-pin" onclick="pressPinKey(5)">5</button></div>
                        <div class="col-4"><button type="button" class="btn btn-pin" onclick="pressPinKey(6)">6</button></div>
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col-4"><button type="button" class="btn btn-pin" onclick="pressPinKey(7)">7</button></div>
                        <div class="col-4"><button type="button" class="btn btn-pin" onclick="pressPinKey(8)">8</button></div>
                        <div class="col-4"><button type="button" class="btn btn-pin" onclick="pressPinKey(9)">9</button></div>
                    </div>
                    <div class="row g-2">
                        <div class="col-4"><button type="button" class="btn btn-pin text-danger" onclick="clearPin()"><i class="bi bi-x-circle"></i></button></div>
                        <div class="col-4"><button type="button" class="btn btn-pin" onclick="pressPinKey(0)">0</button></div>
                        <div class="col-4"><button type="button" class="btn btn-pin text-muted" onclick="backspacePin()"><i class="bi bi-backspace"></i></button></div>
                    </div>
                    
                    <div class="text-center mt-3 text-muted" style="font-size: 10px;">
                        <i class="bi bi-lock-fill me-1"></i> Simulated keypad. You can enter any 6 digits.
                    </div>
                </div>
            </div>

            <!-- 3. SCREEN: PROCESSING -->
            <div id="screenLoading" class="w-100 flex-grow-1 d-none flex-column justify-content-center align-items-center text-center fade-in-up">
                <div class="spinner-border" role="status" style="width: 3rem; height: 3rem; color: var(--primary-rose);">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <h5 class="mt-4" style="font-weight: 700; color: var(--dark-rose);">Processing Transaction</h5>
                <p class="text-muted px-4 mt-1" style="font-size: 13px;">Connecting securely to Moon Books database to settle fine...</p>
            </div>

            <!-- 4. SCREEN: SUCCESS RECEIPT -->
            <div id="screenReceipt" class="w-100 flex-grow-1 d-none flex-column justify-content-between fade-in-up">
                <div class="pay-card text-center mt-2" style="background: white;">
                    <div class="success-icon-container">
                        <i class="bi bi-check2"></i>
                    </div>
                    <h5 class="mt-2 mb-1" style="font-weight: 800; color: var(--success-green); font-size: 18px;">Payment Successful</h5>
                    <small class="text-muted" style="font-size: 11px;">Ref: <span id="receiptRef">MB-REF-000</span></small>

                    <div class="receipt-divider"></div>

                    <div style="text-align: left; font-size: 13px;">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Merchant</span>
                            <strong class="text-dark">Moon Books Library</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Payment Mode</span>
                            <span class="text-dark">QRIS (Simulated)</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Settled Date</span>
                            <span class="text-dark" id="receiptTime">22-06-2026 12:00</span>
                        </div>
                        
                        <hr style="opacity: 0.06; margin: 12px 0;" />
                        
                        <div class="d-flex justify-content-between mb-0" style="font-size: 14px;">
                            <span class="text-muted" style="font-weight: 600;">Total Paid</span>
                            <strong style="color: var(--dark-rose); font-size: 16px;">Rp @((Model.FineAmount ?? 0).ToString("N0"))</strong>
                        </div>
                    </div>
                </div>

                <div class="text-center mb-2 mt-3">
                    <div class="alert alert-success py-2 rounded-3 text-center mb-3" style="border: none; font-size: 11px; color: #155724; background: rgba(40,167,69,0.08); padding: 10px;">
                        <i class="bi bi-pc-display me-1"></i> Library computer screen updated!
                    </div>
                    <p style="font-size: 11px; color: #8c8c8c;">You can safely close this browser tab or window now.</p>
                    <button type="button" class="btn btn-outline-secondary w-100 py-2 rounded-pill" style="font-size: 13px; font-weight: 600;" onclick="window.close();">
                        Close Window
                    </button>
                </div>
            </div>

        </div>
    </div>

    <!-- jQuery & AJAX handler -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        let currentPin = "";

        function goToPinScreen() {
            currentPin = "";
            updatePinDots();
            $("#screenConfirm").removeClass("d-flex").addClass("d-none");
            $("#screenPin").removeClass("d-none").addClass("d-flex");
        }

        function pressPinKey(num) {
            if (currentPin.length < 6) {
                currentPin += num;
                updatePinDots();
                if (currentPin.length === 6) {
                    setTimeout(executePaymentPost, 350);
                }
            }
        }

        function backspacePin() {
            if (currentPin.length > 0) {
                currentPin = currentPin.slice(0, -1);
                updatePinDots();
            }
        }

        function clearPin() {
            currentPin = "";
            updatePinDots();
        }

        function updatePinDots() {
            for (let i = 1; i <= 6; i++) {
                const dot = document.getElementById(`dot${i}`);
                if (dot) {
                    if (i <= currentPin.length) {
                        dot.classList.add("filled");
                    } else {
                        dot.classList.remove("filled");
                    }
                }
            }
        }

        function executePaymentPost() {
            // Transition to loading
            $("#screenPin").removeClass("d-flex").addClass("d-none");
            $("#screenLoading").removeClass("d-none").addClass("d-flex");

            // Perform AJAX POST to database to mark as paid
            $.ajax({
                url: '@Url.Action("PayFineMobileConfirm", "MVCBorrowings", new { id = Model.Id })',
                type: 'POST',
                dataType: 'json',
                success: function (data) {
                    if (data.success) {
                        // Generate receipt details
                        const now = new Date();
                        const dateStr = now.getDate().toString().padStart(2, '0') + '-' + 
                                        (now.getMonth() + 1).toString().padStart(2, '0') + '-' + 
                                        now.getFullYear() + ' ' + 
                                        now.getHours().toString().padStart(2, '0') + ':' + 
                                        now.getMinutes().toString().padStart(2, '0');
                        
                        const refNo = 'MB-' + Math.random().toString(36).substring(2, 10).toUpperCase();

                        $("#receiptTime").text(dateStr);
                        $("#receiptRef").text(refNo);

                        // Show receipt after a small realistic delay
                        setTimeout(function() {
                            $("#screenLoading").removeClass("d-flex").addClass("d-none");
                            $("#screenReceipt").removeClass("d-none").addClass("d-flex");
                        }, 1200);
                    } else {
                        alert("Simulated Payment Error: " + data.message);
                        resetToConfirm();
                    }
                },
                error: function (xhr, status, error) {
                    alert("Network Error during simulation: " + error);
                    resetToConfirm();
                }
            });
        }

        function resetToConfirm() {
            currentPin = "";
            updatePinDots();
            $("#screenLoading").removeClass("d-flex").addClass("d-none");
            $("#screenPin").addClass("d-none").removeClass("d-flex");
            $("#screenConfirm").removeClass("d-none").addClass("d-flex");
        }
    </script>
</body>
</html>
