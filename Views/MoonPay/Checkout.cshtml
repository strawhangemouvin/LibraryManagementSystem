@model LibraryManagementSystem.Models.Entity.Borrowing

@{
    Layout = null;
    string paymentCode = ViewBag.PaymentCode as string ?? $"PAY-MB-{100000 + Model.Id}";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Moon Pay - QRIS checkout</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    
    <style>
        :root {
            --primary-rose: #C97A7E;
            --dark-rose: #4A2E35;
            --light-rose: #FAF5F6;
            --success-green: #28a745;
            --bg-gradient: linear-gradient(135deg, #FAF5F6 0%, #F3E7E8 100%);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: linear-gradient(135deg, rgba(255, 240, 242, 0.85) 0%, rgba(255, 253, 248, 0.75) 50%, rgba(246, 239, 255, 0.85) 100%), url('/Content/library_bg.png') no-repeat center center fixed !important;
            background-size: cover !important;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            color: #333;
            margin: 0;
            padding: 20px;
        }

        .checkout-card {
            width: 100%;
            max-width: 420px;
            background: rgba(255, 255, 255, 0.8) !important;
            border: 1px solid rgba(255, 255, 255, 0.5) !important;
            backdrop-filter: blur(20px) !important;
            -webkit-backdrop-filter: blur(20px) !important;
            border-radius: 32px !important;
            box-shadow: 0 10px 40px rgba(74, 46, 53, 0.08) !important;
            padding: 35px 30px;
            text-align: center;
        }

        .merchant-logo {
            width: 60px;
            height: 60px;
            background: rgba(201, 122, 126, 0.1);
            color: var(--primary-rose);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            margin-bottom: 15px;
        }

        .amount-box {
            background: var(--light-rose);
            border-radius: 20px;
            padding: 20px;
            margin: 20px 0;
            border: 1px solid rgba(201, 122, 126, 0.1);
        }

        .amount-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            margin-bottom: 4px;
        }

        .amount-value {
            font-size: 32px;
            font-weight: 800;
            color: var(--dark-rose);
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            padding: 10px 0;
            border-bottom: 1px solid rgba(0,0,0,0.04);
        }

        .detail-row:last-child {
            border-bottom: none;
        }

        .detail-label {
            color: #7E6569;
        }

        .detail-val {
            font-weight: 600;
            color: #333;
        }

        .btn-pay {
            background: var(--primary-rose);
            color: white;
            border: none;
            font-weight: 700;
            padding: 14px 20px;
            border-radius: 30px;
            box-shadow: 0 4px 15px rgba(201, 122, 126, 0.3);
            transition: all 0.2s ease;
            width: 100%;
            font-size: 16px;
            margin-bottom: 10px;
        }

        .btn-pay:hover:not(:disabled) {
            background: #b56b6f;
            transform: translateY(-1px);
        }

        .btn-pay:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .btn-cancel {
            background: transparent;
            color: #7E6569;
            border: 1.5px solid rgba(0, 0, 0, 0.1);
            font-weight: 600;
            padding: 12px 20px;
            border-radius: 30px;
            transition: all 0.2s ease;
            width: 100%;
            font-size: 14px;
        }

        .btn-cancel:hover:not(:disabled) {
            background: rgba(0,0,0,0.03);
            color: #333;
        }

        /* Success screen overlay */
        .success-overlay {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .success-icon {
            font-size: 64px;
            color: var(--success-green);
            margin-bottom: 15px;
            animation: bounce 0.5s ease;
        }

        @@keyframes bounce {
            0% { transform: scale(0.3); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }
    </style>
</head>
<body>

    <div class="checkout-card">
        <!-- Main Form Content -->
        <div id="paymentForm">
            <div class="merchant-logo">
                <i class="bi bi-wallet2"></i>
            </div>
            <h4 style="font-weight: 700; color: var(--dark-rose); margin-bottom: 2px;">Moon Pay</h4>
            <p class="text-muted" style="font-size: 12px; margin-bottom: 0;">External Payment Gateway Simulator</p>
            
            <div class="amount-box">
                <div class="amount-title">Total Fine Amount</div>
                <div class="amount-value">Rp @((Model.FineAmount ?? 0).ToString("N0"))</div>
            </div>

            <div class="mb-4" style="text-align: left;">
                <div class="detail-row">
                    <span class="detail-label">Billing Code</span>
                    <span class="detail-val">@paymentCode</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Book Title</span>
                    <span class="detail-val text-truncate" style="max-width: 220px;">@(Model.Book != null ? Model.Book.Title : "Book Fine")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Member Code</span>
                    <span class="detail-val">@(Model.Member != null ? Model.Member.MemberCode : "-")</span>
                </div>
            </div>

            <button type="button" id="payBtn" class="btn-pay" onclick="processPayment();">
                <i class="bi bi-shield-check me-1"></i> Pay Fine Now
            </button>
            
            <button type="button" id="cancelBtn" class="btn-cancel" onclick="cancelPayment();">
                Cancel Payment
            </button>
        </div>

        <!-- Success Screen Content -->
        <div id="successScreen" class="success-overlay">
            <i class="bi bi-check-circle-fill success-icon"></i>
            <h4 style="font-weight: 800; color: var(--success-green); margin-bottom: 8px;">Payment Successful</h4>
            <p class="text-muted" style="font-size: 13px; line-height: 1.5;">
                The fine has been paid successfully!<br>The library screen has been updated in real-time.
            </p>
            <small class="text-muted mt-3 d-block" style="font-size: 11px;">Closing this tab in a second...</small>
        </div>
    </div>

    <!-- jQuery & AJAX handler -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Fungsi utama untuk memproses pembayaran denda ketika tombol diklik
        function processPayment() {
            // Menonaktifkan tombol untuk mencegah klik ganda
            $("#payBtn").prop("disabled", true).html('<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Processing...');
            $("#cancelBtn").prop("disabled", true);

            // Melakukan request POST ke server untuk mengonfirmasi pembayaran di database
            $.ajax({
                url: '@Url.Action("ConfirmPayment", "MoonPay", new { id = paymentCode })',
                type: 'POST',
                dataType: 'json',
                success: function (data) {
                    if (data.success) {
                        // Menampilkan animasi layar sukses bayar
                        $("#paymentForm").fadeOut(300, function() {
                            $("#successScreen").fadeIn(300).css("display", "flex");
                        });

                        // Sinkronisasi: Reload tab utama perpustakaan dan tutup tab ini secara otomatis setelah sukses
                        setTimeout(function() {
                            if (window.opener && !window.opener.closed) {
                                try {
                                    window.opener.location.reload();
                                } catch (e) {
                                    console.warn("Parent window reload failed:", e);
                                }
                                window.close();
                            } else {
                                window.location.href = '@Url.Action("Index", "MVCBorrowings")';
                            }
                        }, 1500);
                    } else {
                        alert("Error: " + data.message);
                        resetButtons();
                    }
                },
                error: function (xhr, status, error) {
                    alert("Network Connection Error: " + error);
                    resetButtons();
                }
            });
        }

        // Membatalkan pembayaran dan menutup tab atau kembali ke halaman transaksi
        function cancelPayment() {
            if (window.opener) {
                window.close();
            } else {
                window.location.href = '@Url.Action("Index", "MVCBorrowings")';
            }
        }

        function resetButtons() {
            $("#payBtn").prop("disabled", false).html('<i class="bi bi-shield-check me-1"></i> Pay Fine Now');
            $("#cancelBtn").prop("disabled", false);
        }
    </script>
</body>
</html>
