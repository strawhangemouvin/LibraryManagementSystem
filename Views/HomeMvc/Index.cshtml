    <!-- Curator's Pick Section -->
    <section id="books-pick" class="section-block">
        <div class="section-card">
            <div class="text-center mb-5">
                <span class="section-title-badge">Curated Collections</span>
                <h2 class="section-title">Recommended This Month</h2>
                <p class="section-text mx-auto" style="max-width: 600px;">
                    Explore our most popular and best-selling books, specially curated by our librarians to accompany your weekends.
                </p>
            </div>

            <div class="row g-4">
                @if (Model != null && Model.Any())
                {
                    var gradients = new string[] {
                        "linear-gradient(135deg, #C97A7E 0%, #FFB6C1 100%)",
                        "linear-gradient(135deg, #9C89B8 0%, #B8C0FF 100%)",
                        "linear-gradient(135deg, #E6C587 0%, #FFD5C2 100%)"
                    };
                    int idx = 0;

                    foreach (var book in Model)
                    {
                        <div class="col-md-4">
                            <a href="@Url.Action("Details", "MVCBooks", new { id = book.Id })" class="text-decoration-none w-100 d-block">
                                <div class="book-card">
                                    <div class="book-cover-mock" style="background: @(gradients[idx % gradients.Length]);">
                                        @if (!string.IsNullOrEmpty(book.CoverImage))
                                        {
                                            <img src="@Url.Content(book.CoverImage)" alt="@book.Title" style="width: 100%; height: 100%; object-fit: cover; border-radius: 12px;" />
                                        }
                                        else
                                        {
                                            <i class="bi bi-book-half" style="font-size: 2.8rem;"></i>
                                        }
                                    </div>
                                    <h5 class="book-card-title">@book.Title</h5>
                                    <p class="book-card-author">by @book.Author</p>
                                    <span class="book-card-badge">@(book.Category != null ? book.Category.CategoryName : "General")</span>
                                </div>
                            </a>
                        </div>
                        idx++;
                    }
                }
                else
                {
                    <div class="col-12 text-center py-4">
                        <p class="text-muted">No recommended books available.</p>
                    </div>
                }
            </div>
        </div>
    </section>

