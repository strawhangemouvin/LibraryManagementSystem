@model IEnumerable<LibraryManagementSystem.Models.Entity.Book>
@{
    ViewBag.Title = "Moon Books";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Moon Books</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        :root {
            --primary-rose: #C97A7E;
            --primary-rose-hover: #B56B6B;
            --secondary-peach: #FFD5C2;
            --accent-gold: #E6C587;
            --text-dark: #3A1F24;
            --text-muted: #7E6569;
            --bg-gradient: linear-gradient(135deg, #FFF0F2 0%, #FFFDF8 50%, #F6EFFF 100%);
            --glass-bg: rgba(255, 255, 255, 0.65);
            --glass-border: rgba(255, 255, 255, 0.5);
            --shadow-soft: 0 16px 36px rgba(201, 122, 126, 0.08);
            --shadow-hover: 0 24px 48px rgba(201, 122, 126, 0.16);
            --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Plus Jakarta Sans', Arial, sans-serif;
            background: var(--bg-gradient);
            color: var(--text-dark);
            overflow-x: hidden;
        }

        /* Ambient glows */
        .ambient-glow-1 {
            position: absolute;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255, 182, 193, 0.35) 0%, rgba(255, 255, 255, 0) 70%);
            top: -100px;
            left: -100px;
            z-index: 0;
            pointer-events: none;
        }

        .ambient-glow-2 {
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(224, 176, 255, 0.25) 0%, rgba(255, 255, 255, 0) 70%);
            bottom: 10%;
            right: -100px;
            z-index: 0;
            pointer-events: none;
        }

        /* Navbar Styling */
        .navbar-custom {
            position: sticky;
            top: 0;
            z-index: 999;
            background: rgba(255, 245, 245, 0.8);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            padding: 18px 80px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.02);
            transition: var(--transition-smooth);
        }

        .brand-title {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 800;
            color: var(--text-dark);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
            letter-spacing: -0.5px;
            transition: var(--transition-smooth);
        }

        .brand-title:hover {
            color: var(--primary-rose);
            transform: translateY(-1px);
        }

        .brand-title span {
            color: var(--primary-rose);
        }

        .nav-menu {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-left: auto;
        }

        .nav-link-custom {
            font-size: 15px;
            font-weight: 500;
            color: var(--text-dark);
            text-decoration: none;
            padding: 8px 18px;
            border-radius: 30px;
            transition: var(--transition-smooth);
        }

        .nav-link-custom:hover {
            background: rgba(201, 122, 126, 0.1);
            color: var(--primary-rose);
        }

        .btn-outline-main {
            border: 1.5px solid var(--primary-rose);
            color: var(--primary-rose);
            border-radius: 30px;
            padding: 8px 24px;
            text-decoration: none;
            background: transparent;
            font-weight: 600;
            font-size: 15px;
            transition: var(--transition-smooth);
            display: inline-block;
        }

        .btn-outline-main:hover {
            background: var(--primary-rose);
            color: white;
            box-shadow: 0 8px 20px rgba(201, 122, 126, 0.25);
            transform: translateY(-2px);
        }

        .btn-main {
            background: linear-gradient(135deg, var(--primary-rose) 0%, #E5989B 100%);
            color: white !important;
            border-radius: 30px;
            padding: 10px 28px;
            text-decoration: none;
            font-weight: 600;
            font-size: 15px;
            border: none;
            transition: var(--transition-smooth);
            box-shadow: 0 8px 25px rgba(201, 122, 126, 0.2);
            display: inline-block;
        }

        .btn-main:hover {
            background: linear-gradient(135deg, var(--primary-rose-hover) 0%, var(--primary-rose) 100%);
            box-shadow: 0 12px 30px rgba(201, 122, 126, 0.35);
            transform: translateY(-2px);
        }

        /* Hero Section */
        .hero-section {
            min-height: calc(100vh - 85px);
            display: flex;
            align-items: center;
            padding: 80px;
            position: relative;
            z-index: 1;
        }

        .small-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 255, 255, 0.8);
            border: 1px solid rgba(201, 122, 126, 0.2);
            color: var(--text-dark);
            padding: 6px 16px;
            border-radius: 30px;
            font-size: 13px;
            font-weight: 600;
            box-shadow: 0 4px 15px rgba(201, 122, 126, 0.05);
            margin-bottom: 24px;
            backdrop-filter: blur(4px);
            animation: float 4s ease-in-out infinite;
        }

        .hero-title {
            font-family: 'Playfair Display', serif;
            font-size: 58px;
            font-weight: 800;
            color: var(--text-dark);
            line-height: 1.15;
            letter-spacing: -1px;
            margin-bottom: 24px;
        }

        .hero-title span {
            color: var(--primary-rose);
            position: relative;
            display: inline-block;
        }

        .hero-title span::after {
            content: '';
            position: absolute;
            bottom: 4px;
            left: 0;
            width: 100%;
            height: 8px;
            background: rgba(255, 213, 194, 0.6);
            z-index: -1;
            border-radius: 4px;
        }

        .hero-subtitle {
            font-size: 18px;
            color: var(--text-muted);
            line-height: 1.8;
            margin-bottom: 36px;
            max-width: 580px;
        }

        /* Hero Illustration & Cards */
        .hero-img-container {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .hero-img-backdrop {
            position: absolute;
            width: 110%;
            height: 110%;
            background: radial-gradient(circle, rgba(255, 213, 194, 0.4) 0%, rgba(246, 239, 255, 0.1) 75%);
            z-index: -1;
            border-radius: 50%;
            filter: blur(40px);
        }

        .hero-illustration-img {
            max-width: 100%;
            height: auto;
            border-radius: 40px;
            box-shadow: 0 30px 60px rgba(58, 31, 36, 0.12);
            border: 8px solid white;
            transition: var(--transition-smooth);
            animation: floatBig 6s ease-in-out infinite;
        }

        .hero-illustration-img:hover {
            transform: scale(1.02) rotate(1deg);
            box-shadow: 0 40px 80px rgba(58, 31, 36, 0.18);
        }

        /* Stats Section */
        .stats-row {
            margin-top: 40px;
            display: flex;
            gap: 20px;
        }

        .stat-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: rgba(255, 255, 255, 0.45);
            border: 1px solid rgba(255, 255, 255, 0.55);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 24px;
            padding: 16px 20px;
            min-width: 130px;
            flex: 1;
            box-shadow: 0 8px 24px rgba(74, 46, 53, 0.04);
            transition: var(--transition-smooth);
        }

        .stat-item:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.8);
            border-color: rgba(201, 122, 126, 0.4);
            box-shadow: 0 12px 30px rgba(201, 122, 126, 0.15);
        }

        .stat-number {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 800;
            color: #4A2E35;
            margin-top: 4px;
            margin-bottom: 2px;
        }

        .stat-label {
            font-size: 11px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        /* Glassmorphism Cards */
        .hero-card,
        .section-card,
        .contact-box,
        .about-item,
        .book-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            box-shadow: var(--shadow-soft);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            transition: var(--transition-smooth);
        }

        .hero-card {
            border-radius: 36px;
            padding: 40px;
        }

        .feature-card {
            background: rgba(255, 255, 255, 0.7);
            border-radius: 24px;
            padding: 20px;
            margin-bottom: 20px;
            border: 1px solid rgba(255, 255, 255, 0.6);
            transition: var(--transition-smooth);
            display: flex;
            align-items: center;
        }

        .feature-card:hover {
            background: white;
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 15px 30px rgba(201, 122, 126, 0.1);
            border-color: rgba(201, 122, 126, 0.3);
        }

        .feature-card:last-child {
            margin-bottom: 0;
        }

        .feature-icon {
            font-size: 36px;
            margin-right: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 60px;
            height: 60px;
            background: rgba(255, 213, 194, 0.4);
            border-radius: 18px;
            transition: var(--transition-smooth);
        }

        .feature-card:hover .feature-icon {
            background: var(--primary-rose);
            color: white;
            transform: rotate(10deg);
        }

        .feature-title {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 4px;
        }

        .feature-desc {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 0;
        }

        /* Sections General */
        .section-block {
            padding: 100px 80px;
            position: relative;
            z-index: 1;
            scroll-margin-top: 90px;
        }

        .section-card {
            border-radius: 40px;
            padding: 60px;
        }

        .section-title-badge {
            display: inline-block;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--primary-rose);
            margin-bottom: 12px;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 44px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 24px;
        }

        .section-text {
            font-size: 17px;
            line-height: 1.8;
            color: var(--text-muted);
            margin-bottom: 20px;
        }

        /* Book Cards Section */
        .book-card {
            border-radius: 28px;
            padding: 24px;
            text-align: center;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

        .book-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-hover);
            border-color: rgba(201, 122, 126, 0.4);
        }

        .book-cover-mock {
            width: 130px;
            height: 190px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary-rose) 0%, #FFD5C2 100%);
            box-shadow: 0 12px 25px rgba(58, 31, 36, 0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 40px;
            margin-bottom: 20px;
            position: relative;
            transition: var(--transition-smooth);
        }

        .book-cover-mock::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 8px;
            height: 100%;
            background: rgba(0, 0, 0, 0.08);
            border-top-left-radius: 12px;
            border-bottom-left-radius: 12px;
        }

        .book-card:hover .book-cover-mock {
            transform: scale(1.05) rotate(-3deg);
            box-shadow: 0 16px 30px rgba(58, 31, 36, 0.25);
        }

        .book-card-title {
            font-family: 'Playfair Display', serif;
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 6px;
            color: var(--text-dark);
        }

        .book-card-author {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 12px;
        }

        .book-card-badge {
            background: rgba(201, 122, 126, 0.1);
            color: var(--primary-rose);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
        }

        /* About Section Design */
        .moon-art-container {
            position: relative;
            display: inline-block;
            margin-bottom: 24px;
        }

        .moon-big-new {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: linear-gradient(135deg, #FFF9F2 0%, #FFE5D9 100%);
            box-shadow: inset -24px 0 0 #FFCAD4, 0 10px 40px rgba(255, 182, 193, 0.5);
            margin: 0 auto;
            position: relative;
            animation: spinSlow 30s linear infinite;
        }

        .moon-sparkle {
            position: absolute;
            font-size: 24px;
            color: var(--accent-gold);
            animation: pulse 2s ease-in-out infinite;
        }

        .moon-sparkle-1 { top: 10px; right: 10px; }
        .moon-sparkle-2 { bottom: 20px; left: -10px; animation-delay: 1s; }

        .about-item {
            border-radius: 28px;
            padding: 30px 24px;
            height: 100%;
            text-align: center;
        }

        .about-item:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-hover);
            border-color: rgba(201, 122, 126, 0.3);
        }

        .about-icon {
            font-size: 38px;
            margin-bottom: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 70px;
            height: 70px;
            background: rgba(255, 213, 194, 0.35);
            border-radius: 22px;
            transition: var(--transition-smooth);
            color: var(--primary-rose);
        }

        .about-item:hover .about-icon {
            background: var(--primary-rose);
            color: white !important;
            transform: scale(1.1) rotate(5deg);
        }

        /* Contact Details */
        .contact-box {
            border-radius: 28px;
            padding: 30px;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 15px;
        }

        .contact-box:hover {
            transform: translateY(-5px);
            border-color: rgba(201, 122, 126, 0.3);
            box-shadow: var(--shadow-hover);
        }

        .contact-icon {
            font-size: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 56px;
            height: 56px;
            background: rgba(255, 213, 194, 0.4);
            border-radius: 18px;
            flex-shrink: 0;
            color: var(--primary-rose);
        }

        .contact-info-title {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 4px;
        }

        .contact-info-text {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 0;
            line-height: 1.6;
            word-break: break-all;
        }

        /* Form Controls */
        .form-control {
            border-radius: 16px;
            border: 1px solid rgba(201, 122, 126, 0.25);
            padding: 14px 20px;
            background: rgba(255, 255, 255, 0.8);
            color: var(--text-dark);
            font-size: 15px;
            transition: var(--transition-smooth);
        }

        .form-control:focus {
            border-color: var(--primary-rose);
            background: white;
            box-shadow: 0 0 0 4px rgba(201, 122, 126, 0.12);
            color: var(--text-dark);
        }

        .form-label {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 8px;
            margin-left: 4px;
        }

        /* Footer */
        .footer-custom {
            background: radial-gradient(circle at 10% 20%, #4A2E35 0%, #301A1E 100%);
            color: #F6EFFF;
            padding: 80px 80px 30px 80px;
            position: relative;
            overflow: hidden;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .footer-custom::before {
            content: '';
            position: absolute;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(201, 122, 126, 0.1) 0%, rgba(0, 0, 0, 0) 70%);
            bottom: -100px;
            left: -100px;
            pointer-events: none;
        }

        .footer-title {
            font-family: 'Playfair Display', serif;
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 20px;
            color: white;
        }

        .footer-desc {
            font-size: 14px;
            line-height: 1.8;
            opacity: 0.8;
            margin-bottom: 20px;
        }

        .footer-heading {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 20px;
            color: white;
            position: relative;
            padding-bottom: 8px;
        }

        .footer-heading::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: var(--primary-rose);
            border-radius: 2px;
        }

        .footer-link {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #E5D9DC;
            text-decoration: none;
            margin-bottom: 12px;
            font-size: 14px;
            transition: var(--transition-smooth);
        }

        .text-center .footer-link {
            justify-content: center;
        }

        .text-center .footer-heading::after {
            left: 50%;
            transform: translateX(-50%);
        }

        .footer-link::before {
            content: '\2726';
            font-size: 10px;
            color: var(--primary-rose);
            opacity: 0;
            transition: var(--transition-smooth);
            transform: translateX(-5px);
        }

        .footer-link:hover {
            color: white;
            padding-left: 8px;
        }

        .text-center .footer-link:hover {
            padding-left: 0;
        }

        .footer-link:hover::before {
            opacity: 1;
            transform: translateX(0);
        }

        .footer-badge {
            display: inline-block;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #F6EFFF;
            padding: 6px 14px;
            border-radius: 20px;
            margin: 0 6px 10px 0;
            font-size: 13px;
            transition: var(--transition-smooth);
        }

        .footer-badge:hover {
            background: var(--primary-rose);
            border-color: var(--primary-rose);
            transform: translateY(-2px);
        }

        .footer-bottom {
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            margin-top: 50px;
            padding-top: 25px;
            text-align: center;
            font-size: 14px;
            opacity: 0.7;
        }

        /* Animations */
        @@keyframes float {
            0% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-8px) rotate(1deg); }
            100% { transform: translateY(0px) rotate(0deg); }
        }

        @@keyframes floatBig {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-15px); }
            100% { transform: translateY(0px); }
        }

        @@keyframes pulse {
            0% { transform: scale(1); opacity: 0.6; }
            50% { transform: scale(1.2); opacity: 1; }
            100% { transform: scale(1); opacity: 0.6; }
        }

        @@keyframes spinSlow {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Media Queries */
        @@media (max-width: 1200px) {
            .hero-title {
                font-size: 46px;
            }
        }

        @@media (max-width: 992px) {
            .navbar-custom {
                padding: 16px 30px;
            }

            .nav-menu {
                gap: 8px;
            }

            .hero-section {
                padding: 60px 30px;
                min-height: auto;
            }

            .hero-title {
                font-size: 40px;
            }

            .section-block {
                padding: 60px 30px;
            }

            .section-card {
                padding: 40px 24px;
            }

            .footer-custom {
                padding: 60px 30px 20px 30px;
            }
        }

        @@media (max-width: 576px) {
            .brand-title {
                font-size: 22px;
            }
            .nav-menu {
                display: none;
            }
            .stats-row {
                flex-direction: column;
                gap: 15px;
            }
        }
    </style>
</head>

<body>
    <div class="ambient-glow-1"></div>
    <div class="ambient-glow-2"></div>

    <nav class="navbar-custom d-flex align-items-center">
        <a class="brand-title" href="#home">
            <i class="bi bi-moon-stars-fill me-2" style="color: var(--primary-rose);"></i>Moon <span>Books</span>
        </a>

        <div class="nav-menu">
            <a href="#home" class="nav-link-custom">Home</a>
            <a href="#about" class="nav-link-custom">About</a>
            <a href="#books-pick" class="nav-link-custom">Featured</a>
            <a href="#contact" class="nav-link-custom">Contact</a>
            <a href="@Url.Action("Login", "AuthMvc")" class="btn-outline-main">Sign In</a>
            <a href="@Url.Action("Register", "AuthMvc")" class="btn-main">Sign Up</a>
        </div>
    </nav>

    <section id="home" class="hero-section">
        <div class="container-fluid">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-5 mb-lg-0">
                    <span class="small-badge">
                        <i class="bi bi-sparkles me-2" style="color: var(--primary-rose);"></i>Curated &amp; Aesthetic Digital Library
                    </span>

                    <h1 class="hero-title">
                        Read &amp; Manage Books with an <span>Aesthetic</span> Touch
                    </h1>

                    <p class="hero-subtitle">
                        Moon Books offers a warm and delightful digital reading space. Simplify book cataloging, borrowings, and return reminders with our modern, dynamic system.
                    </p>

                    <div class="mb-4">
