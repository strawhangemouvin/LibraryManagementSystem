    <script>
        const contactEmailInput = document.getElementById("contactEmail");
        const atSym = String.fromCharCode(64);

        if (contactEmailInput) {
            function validateEmail() {
                let value = contactEmailInput.value.trim().toLowerCase();
                const emailPattern = /^[^\u0040\s]+\u0040(gmail\.com|yahoo\.com|email\.com)$/;
                if (!emailPattern.test(value)) {
                    contactEmailInput.setCustomValidity("Email must use \u0040gmail.com, \u0040yahoo.com, or \u0040email.com domain.");
                } else {
                    contactEmailInput.setCustomValidity("");
                }
            }

            contactEmailInput.addEventListener("input", function () {
                let value = contactEmailInput.value.trim().toLowerCase();

                if (value.endsWith(atSym + "g")) {
                    contactEmailInput.value = value.substring(0, value.length - 2) + atSym + "gmail.com";
                    moveCursorToEnd(contactEmailInput);
                    validateEmail();
                    return;
                }

                if (value.endsWith(atSym + "gm")) {
                    contactEmailInput.value = value.substring(0, value.length - 3) + atSym + "gmail.com";
                    moveCursorToEnd(contactEmailInput);
                    validateEmail();
                    return;
                }

                if (value.endsWith(atSym + "gmail")) {
                    contactEmailInput.value = value.substring(0, value.length - 6) + atSym + "gmail.com";
                    moveCursorToEnd(contactEmailInput);
                    validateEmail();
                    return;
                }

                if (value.endsWith(atSym + "y")) {
                    contactEmailInput.value = value.substring(0, value.length - 2) + atSym + "yahoo.com";
                    moveCursorToEnd(contactEmailInput);
                    validateEmail();
                    return;
                }

                if (value.endsWith(atSym + "ya")) {
                    contactEmailInput.value = value.substring(0, value.length - 3) + atSym + "yahoo.com";
                    moveCursorToEnd(contactEmailInput);
                    validateEmail();
                    return;
                }

                if (value.endsWith(atSym + "yahoo")) {
                    contactEmailInput.value = value.substring(0, value.length - 6) + atSym + "yahoo.com";
                    moveCursorToEnd(contactEmailInput);
                    validateEmail();
                    return;
                }

                if (value.endsWith(atSym + "e")) {
                    contactEmailInput.value = value.substring(0, value.length - 2) + atSym + "email.com";
                    moveCursorToEnd(contactEmailInput);
                    validateEmail();
                    return;
                }

                if (value.endsWith(atSym + "email")) {
                    contactEmailInput.value = value.substring(0, value.length - 6) + atSym + "email.com";
                    moveCursorToEnd(contactEmailInput);
                    validateEmail();
                    return;
                }

                validateEmail();
            });

            // Initialize validation check on startup/first load
            validateEmail();
        }

        function moveCursorToEnd(input) {
            setTimeout(function () {
                input.selectionStart = input.selectionEnd = input.value.length;
            }, 0);
        }
    </script>

