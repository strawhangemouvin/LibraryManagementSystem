@{
    ViewBag.Title = "Library Management System";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Library Management System</title>

    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(135deg, #FDF6F0, #F7D9E3);
            font-family: 'Segoe UI', Arial, sans-serif;
            color: #4B3A42;
        }

        .navbar-custom {
            padding: 20px 60px;
        }

        .brand-title {
            font-size: 24px;
            font-weight: 700;
            color: #7A4E60;
            text-decoration: none;
        }

        .hero-section {
            min-height: calc(100vh - 90px);
            display: flex;
            align-items: center;
            padding: 40px 70px;
        }

        .hero-title {
            font-size: 54px;
            font-weight: 800;
            color: #7A4E60;
            line-height: 1.15;
        }

        .hero-subtitle {
            font-size: 18px;
            color: #6B5B63;
            margin-top: 20px;
            max-width: 580px;
        }

        .hero-card {
            background: rgba(255, 255, 255, 0.78);
            border-radius: 28px;
            padding: 35px;
            box-shadow: 0 12px 35px rgba(122, 78, 96, 0.18);
        }

        .feature-card {
            background: #FFFFFF;
            border-radius: 20px;
            padding: 18px;
            margin-bottom: 16px;
            box-shadow: 0 8px 20px rgba(122, 78, 96, 0.10);
        }

        .feature-icon {
            font-size: 34px;
            margin-right: 15px;
        }

        .btn-main {
            background-color: #7A4E60;
            color: white;
            border-radius: 30px;
            padding: 10px 24px;
            border: none;
            text-decoration: none;
        }

            .btn-main:hover {
                background-color: #633C4D;
                color: white;
            }

        .btn-outline-main {
            border: 1px solid #7A4E60;
            color: #7A4E60;
            border-radius: 30px;
            padding: 10px 24px;
            text-decoration: none;
            background-color: transparent;
        }

            .btn-outline-main:hover {
                background-color: #7A4E60;
                color: white;
            }

        .library-illustration {
            font-size: 120px;
            text-align: center;
            margin-bottom: 10px;
        }

        .small-badge {
            display: inline-block;
            background-color: #ffffff;
            color: #7A4E60;
            padding: 8px 16px;
            border-radius: 30px;
            font-size: 14px;
            box-shadow: 0 6px 18px rgba(122, 78, 96, 0.12);
            margin-bottom: 18px;
        }

        @@media (max-width: 768px) {
            .navbar-custom {
                padding: 18px 25px;
            }

            .hero-section {
                padding: 30px 25px;
            }

            .hero-title {
                font-size: 38px;
            }

            .library-illustration {
                font-size: 80px;
            }
        }
    </style>
</head>

<body>
    <a class="brand-title" href="@Url.Action("Index", "HomeMvc")">
        📚 Library Management
    </a>

    <a href="@Url.Action("Index", "HomeMvc")" class="btn-outline-main me-2">
        Home
    </a>

    <a href="@Url.Action("About", "HomeMvc")" class="btn-outline-main me-2">
        About
    </a>

    <a href="@Url.Action("Contact", "HomeMvc")" class="btn-outline-main me-2">
        Contact
    </a>

    <a href="@Url.Action("Login", "AuthMvc")" class="btn-outline-main me-2">
        Sign In
    </a>

    <a href="@Url.Action("Register", "AuthMvc")" class="btn-main">
        Sign Up
    </a>

    <section class="hero-section">
        <div class="container-fluid">
            <div class="row align-items-center">

                <div class="col-lg-6 mb-4">
                    <span class="small-badge">
                        Sistem Manajemen Perpustakaan Digital
                    </span>

                    <h1 class="hero-title">
                        Kelola Buku, Member, dan Peminjaman dengan Lebih Mudah
                    </h1>

                    <p class="hero-subtitle">
                        Website ini membantu pustakawan dalam mengelola data buku, kategori,
                        member, peminjaman, pengembalian, laporan, serta denda keterlambatan
                        secara lebih rapi dan terstruktur.
                    </p>

                    <div class="mt-4">
                        <a href="@Url.Action("Login", "AuthMvc")" class="btn-main me-2">
                            Mulai Sekarang
                        </a>

                        <a href="@Url.Action("Register", "AuthMvc")" class="btn-outline-main">
                            Daftar Member
                        </a>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="hero-card">
                        <div class="library-illustration">
                            📖
                        </div>

                        <div class="feature-card d-flex align-items-center">
                            <div class="feature-icon">📚</div>
                            <div>
                                <h6 class="mb-1">Manajemen Buku</h6>
                                <small class="text-muted">Mengelola data buku, stok, kategori, dan detail buku.</small>
                            </div>
                        </div>

                        <div class="feature-card d-flex align-items-center">
                            <div class="feature-icon">👥</div>
                            <div>
                                <h6 class="mb-1">Manajemen Member</h6>
                                <small class="text-muted">Pustakawan dapat menyetujui atau menolak akun member.</small>
                            </div>
                        </div>

                        <div class="feature-card d-flex align-items-center">
                            <div class="feature-icon">🔁</div>
                            <div>
                                <h6 class="mb-1">Peminjaman & Pengembalian</h6>
                                <small class="text-muted">Member dapat mengajukan peminjaman dan melihat riwayatnya.</small>
                            </div>
                        </div>

                        <div class="feature-card d-flex align-items-center">
                            <div class="feature-icon">📊</div>
                            <div>
                                <h6 class="mb-1">Laporan Perpustakaan</h6>
                                <small class="text-muted">Menampilkan laporan buku, member, dan status peminjaman.</small>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>
</body>
</html>
