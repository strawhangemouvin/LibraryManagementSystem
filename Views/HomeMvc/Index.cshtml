
@{
    ViewBag.Title = "Moon Books";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Moon Books</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />

    <style>
        html {
            scroll-behavior: smooth;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #FFF8EC, #F6E7CF, #EBD6B8);
            color: #4A3526;
        }

        .navbar-custom {
            position: sticky;
            top: 0;
            z-index: 999;
            background: rgba(255, 248, 236, 0.95);
            backdrop-filter: blur(12px);
            padding: 16px 60px;
            box-shadow: 0 5px 20px rgba(103, 70, 38, 0.10);
            border-bottom: 1px solid rgba(139, 98, 57, 0.15);
        }

        .brand-title {
            font-size: 26px;
            font-weight: 800;
            color: #7B4F2C;
            text-decoration: none;
            white-space: nowrap;
        }

        .brand-title:hover {
            color: #5F3A1E;
        }

        .nav-menu {
            width: 100%;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 10px;
        }

        .nav-link-custom,
        .btn-outline-main {
            border: 1px solid #7B4F2C;
            color: #7B4F2C;
            border-radius: 30px;
            padding: 9px 22px;
            text-decoration: none;
            background: transparent;
            font-weight: 500;
            transition: 0.2s;
        }

        .nav-link-custom:hover,
        .btn-outline-main:hover {
            background: #7B4F2C;
            color: #FFF8EC;
        }

        .btn-main {
            background: #7B4F2C;
            color: #FFF8EC;
            border-radius: 30px;
            padding: 10px 24px;
            text-decoration: none;
            font-weight: 600;
            border: none;
            transition: 0.2s;
        }

        .btn-main:hover {
            background: #5F3A1E;
            color: #FFF8EC;
        }

        .hero-section {
            min-height: calc(100vh - 82px);
            display: flex;
            align-items: center;
            padding: 70px;
            position: relative;
            overflow: hidden;
        }

        .hero-section::before {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(255, 252, 245, 0.75);
            box-shadow: 0 0 90px rgba(255, 252, 245, 0.95);
            right: -80px;
            top: 80px;
        }

        .hero-section::after {
            content: "✦";
            position: absolute;
            font-size: 46px;
            color: rgba(123, 79, 44, 0.22);
            left: 55%;
            top: 16%;
        }

        .hero-section .container-fluid {
            position: relative;
            z-index: 1;
        }

        .small-badge {
            display: inline-block;
            background: #FFFCF5;
            color: #7B4F2C;
            padding: 8px 18px;
            border-radius: 30px;
            font-size: 14px;
            box-shadow: 0 6px 18px rgba(103, 70, 38, 0.12);
            margin-bottom: 18px;
        }

        .hero-title {
            font-size: 56px;
            font-weight: 850;
            color: #7B4F2C;
            line-height: 1.15;
        }

        .hero-subtitle {
            font-size: 18px;
            color: #6F5439;
            margin-top: 20px;
            max-width: 620px;
            line-height: 1.7;
        }

        .hero-card,
        .section-card,
        .contact-box,
        .about-item {
            background: rgba(255, 252, 245, 0.88);
            border: 1px solid rgba(139, 98, 57, 0.10);
            box-shadow: 0 14px 34px rgba(103, 70, 38, 0.13);
        }

        .hero-card {
            border-radius: 32px;
            padding: 36px;
        }

        .library-illustration {
            font-size: 115px;
            text-align: center;
            margin-bottom: 10px;
        }

        .feature-card {
            background: #FFFCF5;
            border-radius: 22px;
            padding: 18px;
            margin-bottom: 16px;
            box-shadow: 0 8px 20px rgba(103, 70, 38, 0.09);
            border: 1px solid rgba(139, 98, 57, 0.08);
        }

        .feature-icon {
            font-size: 34px;
            margin-right: 15px;
        }

        .section-block {
            padding: 90px 70px;
            scroll-margin-top: 95px;
        }

        .section-card {
            border-radius: 32px;
            padding: 46px;
        }

        .section-title {
            font-size: 42px;
            font-weight: 850;
            color: #7B4F2C;
            margin-bottom: 18px;
        }

        .section-text {
            font-size: 17px;
            line-height: 1.8;
            color: #6F5439;
        }

        .moon-big {
            width: 165px;
            height: 165px;
            border-radius: 50%;
            background: #FFF8EC;
            box-shadow: inset -34px 0 0 #EBD6B8, 0 0 50px rgba(255, 248, 236, 0.95);
            margin: 0 auto 20px auto;
        }

        .about-item {
            border-radius: 22px;
            padding: 22px;
            height: 100%;
        }

        .about-icon,
        .contact-icon {
            font-size: 36px;
            margin-bottom: 12px;
        }

        .contact-box {
            border-radius: 24px;
            padding: 24px;
            height: 100%;
        }

        .form-control {
            border-radius: 16px;
            border: 1px solid #D8BA91;
            padding: 12px;
            background: #FFFCF5;
            color: #4A3526;
        }

        .form-control:focus {
            border-color: #7B4F2C;
            box-shadow: 0 0 0 0.2rem rgba(123, 79, 44, 0.15);
        }

        .footer-custom {
            background: #7B4F2C;
            color: #FFF8EC;
            padding: 50px 70px 25px 70px;
        }

        .footer-title {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 12px;
        }

        .footer-link {
            display: block;
            color: #FFF8EC;
            text-decoration: none;
            margin-bottom: 8px;
            opacity: 0.92;
        }

        .footer-link:hover {
            color: white;
            text-decoration: underline;
            opacity: 1;
        }

        .footer-badge {
            display: inline-block;
            background: rgba(255, 248, 236, 0.16);
            color: #FFF8EC;
            padding: 8px 14px;
            border-radius: 20px;
            margin: 4px 4px 4px 0;
            font-size: 13px;
        }

        .footer-bottom {
            border-top: 1px solid rgba(255, 248, 236, 0.25);
            margin-top: 30px;
            padding-top: 18px;
            text-align: center;
            font-size: 14px;
            opacity: 0.92;
        }

        @@media (max-width: 992px) {
            .navbar-custom {
                padding: 16px 25px;
            }

            .nav-menu {
                flex-wrap: wrap;
                justify-content: flex-end;
            }

            .hero-section,
            .section-block {
                padding: 50px 25px;
            }

            .hero-title {
                font-size: 40px;
            }

            .library-illustration {
                font-size: 85px;
            }

            .footer-custom {
                padding: 40px 25px 20px 25px;
            }
        }
    </style>
</head>

<body>
    <nav class="navbar-custom d-flex align-items-center">
        <a class="brand-title" href="#home">
            🌙📚 Moon Books
        </a>

        <div class="nav-menu">
            <a href="#home" class="nav-link-custom">Home</a>
            <a href="#about" class="nav-link-custom">About</a>
            <a href="#contact" class="nav-link-custom">Contact</a>
            <a href="@Url.Action("Login", "AuthMvc")" class="btn-outline-main">Sign In</a>
            <a href="@Url.Action("Register", "AuthMvc")" class="btn-main">Sign Up</a>
        </div>
    </nav>

    <section id="home" class="hero-section">
        <div class="container-fluid">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-4">
                    <span class="small-badge">
                        🌙 Sistem Manajemen Perpustakaan Digital
                    </span>

                    <h1 class="hero-title">
                        Kelola Buku, Member, dan Peminjaman dengan Lebih Mudah
                    </h1>

                    <p class="hero-subtitle">
                        Moon Books membantu pustakawan dalam mengelola data buku, kategori,
                        member, peminjaman, pengembalian, laporan, reminder jatuh tempo,
                        serta denda keterlambatan secara rapi dan terstruktur.
                    </p>

                    <div class="mt-4">
                        <a href="@Url.Action("Login", "AuthMvc")" class="btn-main me-2">
                            Mulai Sekarang
                        </a>

                        <a href="@Url.Action("Register", "AuthMvc")" class="btn-outline-main">
                            Daftar Member
                        </a>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="hero-card">
                        <div class="library-illustration">
                            🌙📖
                        </div>

                        <div class="feature-card d-flex align-items-center">
                            <div class="feature-icon">📚</div>
                            <div>
                                <h6 class="mb-1">Manajemen Buku</h6>
                                <small class="text-muted">Mengelola data buku, stok, kategori, dan detail buku.</small>
                            </div>
                        </div>

                        <div class="feature-card d-flex align-items-center">
                            <div class="feature-icon">👥</div>
                            <div>
                                <h6 class="mb-1">Manajemen Member</h6>
                                <small class="text-muted">Pustakawan dapat menyetujui atau menolak akun member.</small>
                            </div>
                        </div>

                        <div class="feature-card d-flex align-items-center">
                            <div class="feature-icon">🔁</div>
                            <div>
                                <h6 class="mb-1">Peminjaman & Pengembalian</h6>
                                <small class="text-muted">Member dapat mengajukan peminjaman dan melihat riwayatnya.</small>
                            </div>
                        </div>

                        <div class="feature-card d-flex align-items-center">
                            <div class="feature-icon">💳</div>
                            <div>
                                <h6 class="mb-1">Denda & QRIS Simulasi</h6>
                                <small class="text-muted">Denda keterlambatan dapat dicatat dan dibayar melalui QRIS simulasi.</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="about" class="section-block">
        <div class="section-card">
            <div class="row align-items-center">
                <div class="col-lg-7 mb-4">
                    <h2 class="section-title">Tentang Moon Books</h2>

                    <p class="section-text">
                        Moon Books adalah website manajemen perpustakaan bernuansa hangat
                        yang dibuat untuk membantu pengelolaan buku, member, peminjaman,
                        pengembalian, laporan, reminder, dan denda keterlambatan secara digital.
                    </p>

                    <p class="section-text">
                        Website ini memiliki dua jenis pengguna, yaitu <b>Pustakawan</b> dan
                        <b>Member</b>. Pustakawan dapat mengelola data perpustakaan dan memproses
                        peminjaman, sedangkan member dapat melihat buku, mengajukan peminjaman,
                        serta memantau riwayat peminjamannya.
                    </p>
                </div>

                <div class="col-lg-5 text-center">
                    <div class="moon-big"></div>
                    <h4 style="color:#7B4F2C;">A Warm Digital Library</h4>
                    <p class="text-muted">Ruang digital yang rapi, hangat, dan nyaman untuk mengelola buku.</p>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-md-3 mb-3">
                    <div class="about-item">
                        <div class="about-icon">📚</div>
                        <h6>Data Buku</h6>
                        <p class="text-muted mb-0">Mengelola stok, kategori, detail, dan ketersediaan buku.</p>
                    </div>
                </div>

                <div class="col-md-3 mb-3">
                    <div class="about-item">
                        <div class="about-icon">👥</div>
                        <h6>Data Member</h6>
                        <p class="text-muted mb-0">Registrasi member dapat disetujui atau ditolak pustakawan.</p>
                    </div>
                </div>

                <div class="col-md-3 mb-3">
                    <div class="about-item">
                        <div class="about-icon">⏰</div>
                        <h6>Reminder</h6>
                        <p class="text-muted mb-0">Member mendapatkan pengingat saat jatuh tempo mendekat.</p>
                    </div>
                </div>

                <div class="col-md-3 mb-3">
                    <div class="about-item">
                        <div class="about-icon">💳</div>
                        <h6>Denda</h6>
                        <p class="text-muted mb-0">Denda keterlambatan dapat dicatat dan dibayar melalui QRIS simulasi.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="section-block">
        <div class="section-card">
            <div class="row">
                <div class="col-lg-6 mb-4">
                    <h2 class="section-title">Contact</h2>

                    <p class="section-text">
                        Jika terdapat kendala pada proses registrasi, login, peminjaman,
                        pengembalian, atau pembayaran denda, silakan hubungi pihak pustakawan.
                    </p>

                    <div class="row mt-4">
                        <div class="col-md-6 mb-3">
                            <div class="contact-box">
                                <div class="contact-icon">📍</div>
                                <h6>Alamat</h6>
                                <p class="text-muted mb-0">
                                    Perpustakaan Moon Books<br />
                                    Indonesia
                                </p>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="contact-box">
                                <div class="contact-icon">✉️</div>
                                <h6>Email</h6>
                                <p class="text-muted mb-0">
                                    moonbooks@email.com
                                </p>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="contact-box">
                                <div class="contact-icon">📞</div>
                                <h6>Telepon</h6>
                                <p class="text-muted mb-0">
                                    08xx-xxxx-xxxx
                                </p>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="contact-box">
                                <div class="contact-icon">⏰</div>
                                <h6>Jam Layanan</h6>
                                <p class="text-muted mb-0">
                                    Senin - Jumat<br />
                                    08.00 - 16.00
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="contact-box">
                        <h4 style="color:#7B4F2C;">Form Pesan</h4>
                        <p class="text-muted">
                            Form ini digunakan sebagai tampilan kontak pada website.
                        </p>

                        <form>
                            <div class="mb-3">
                                <label class="form-label">Nama</label>
                                <input type="text" class="form-control" placeholder="Masukkan nama Anda" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" placeholder="Masukkan email Anda" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Pesan</label>
                                <textarea class="form-control" rows="5" placeholder="Tulis pesan Anda"></textarea>
                            </div>

                            <button type="button" class="btn-main">
                                Kirim Pesan
                            </button>

                            <small class="text-muted d-block mt-3">
                                Catatan: form ini masih tampilan simulasi dan belum mengirim pesan ke database.
                            </small>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="footer-custom">
        <div class="row">
            <div class="col-lg-4 mb-4">
                <div class="footer-title">🌙📚 Moon Books</div>
                <p>
                    Moon Books adalah sistem manajemen perpustakaan digital dengan konsep hangat,
                    rapi, dan mudah digunakan.
                </p>
            </div>

            <div class="col-lg-2 col-md-4 mb-4">
                <h6>Quick Links</h6>
                <a href="#home" class="footer-link">Home</a>
                <a href="#about" class="footer-link">About</a>
                <a href="#contact" class="footer-link">Contact</a>
                <a href="@Url.Action("Login", "AuthMvc")" class="footer-link">Sign In</a>
                <a href="@Url.Action("Register", "AuthMvc")" class="footer-link">Sign Up</a>
            </div>

            <div class="col-lg-3 col-md-4 mb-4">
                <h6>Fitur</h6>
                <span class="footer-badge">Manajemen Buku</span>
                <span class="footer-badge">Member</span>
                <span class="footer-badge">Peminjaman</span>
                <span class="footer-badge">Pengembalian</span>
                <span class="footer-badge">Reminder</span>
                <span class="footer-badge">QRIS Simulasi</span>
            </div>

            <div class="col-lg-3 col-md-4 mb-4">
                <h6>Contact</h6>
                <p class="mb-1">📍 Indonesia</p>
                <p class="mb-1">✉️ moonbooks@email.com</p>
                <p class="mb-1">📞 08xx-xxxx-xxxx</p>
                <p class="mb-0">⏰ Senin - Jumat, 08.00 - 16.00</p>
            </div>
        </div>

        <div class="footer-bottom">
            © @DateTime.Now.Year Moon Books. All rights reserved.
        </div>
    </footer>
</body>
</html>
