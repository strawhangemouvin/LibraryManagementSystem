@model LibraryManagementSystem.Models.Entity.Book

@{
    ViewBag.Title = "Edit Book";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0 rounded-4" style="max-width: 800px; margin: 0 auto; background: rgba(255, 255, 255, 0.45); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.25);">
        <div class="card-header border-0 rounded-top-4" style="background-color: var(--primary-rose) !important; color: var(--text-dark); padding: 20px;">
            <h4 class="mb-0" style="font-family: 'Playfair Display', serif; font-weight: 700; color: var(--text-dark) !important;">Edit Book Info</h4>
            <p class="mb-0 text-muted" style="font-size: 13px; color: var(--text-dark) !important; opacity: 0.85;">Update the catalog details for this book.</p>
        </div>

        <div class="card-body p-4">
            @using (Html.BeginForm("Edit", "MVCBooks", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })
                @Html.HiddenFor(model => model.Id)

                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label" style="font-weight: 600; color: var(--text-dark);">Book Title</label>
                            @Html.TextBoxFor(model => model.Title, new { @class = "form-control", placeholder = "Enter book title", required = "required" })
                            @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="font-weight: 600; color: var(--text-dark);">Author</label>
                            @Html.TextBoxFor(model => model.Author, new { @class = "form-control", placeholder = "Enter author name", required = "required" })
                            @Html.ValidationMessageFor(model => model.Author, "", new { @class = "text-danger small" })
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" style="font-weight: 600; color: var(--text-dark);">Category</label>
                                @Html.DropDownList("CategoryId", null, htmlAttributes: new { @class = "form-select" })
                                @Html.ValidationMessageFor(model => model.CategoryId, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label" style="font-weight: 600; color: var(--text-dark);">Publisher</label>
                                @Html.TextBoxFor(model => model.Publisher, new { @class = "form-control", placeholder = "Enter publisher name" })
                                @Html.ValidationMessageFor(model => model.Publisher, "", new { @class = "text-danger small" })
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label" style="font-weight: 600; color: var(--text-dark);">Publish Year</label>
                                @Html.TextBoxFor(model => model.PublishYear, new { @class = "form-control", type = "number", placeholder = "YYYY" })
                                @Html.ValidationMessageFor(model => model.PublishYear, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label" style="font-weight: 600; color: var(--text-dark);">ISBN</label>
                                @Html.TextBoxFor(model => model.ISBN, new { @class = "form-control", placeholder = "ISBN Number" })
                                @Html.ValidationMessageFor(model => model.ISBN, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label" style="font-weight: 600; color: var(--text-dark);">Stock Quantity</label>
                                @Html.TextBoxFor(model => model.Stock, new { @class = "form-control", type = "number", min = "0", placeholder = "Total stock", required = "required" })
                                @Html.ValidationMessageFor(model => model.Stock, "", new { @class = "text-danger small" })
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label" style="font-weight: 600; color: var(--text-dark);">Book Cover Image</label>
                            <div class="border rounded-4 p-3 text-center bg-white bg-opacity-50" style="border-style: dashed !important; border-color: var(--primary-rose) !important;">
                                @if (!string.IsNullOrEmpty(Model.CoverImage))
                                {
                                    <i class="bi bi-image text-muted d-none" style="font-size: 48px;" id="coverPlaceholderIcon"></i>
                                    <img id="coverPreview" src="@Model.CoverImage" alt="Cover Preview" class="img-fluid rounded-3 mb-2" style="max-height: 200px; object-fit: cover;" />
                                }
                                else
                                {
                                    <i class="bi bi-image text-muted" style="font-size: 48px;" id="coverPlaceholderIcon"></i>
                                    <img id="coverPreview" src="#" alt="Cover Preview" class="img-fluid rounded-3 mb-2 d-none" style="max-height: 200px; object-fit: cover;" />
                                }
                                <p class="small text-muted mb-2">Upload a cover image (JPG, PNG)</p>
                                <input type="file" name="coverImageFile" id="coverImageFile" class="form-control form-control-sm" accept="image/*" />
                            </div>
                            @Html.ValidationMessageFor(model => model.CoverImage, "", new { @class = "text-danger small mt-1 d-block" })
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label" style="font-weight: 600; color: var(--text-dark);">Description</label>
                    @Html.TextAreaFor(model => model.Description, new { @class = "form-control", rows = "3", placeholder = "Enter brief description or summary of the book" })
                    @Html.ValidationMessageFor(model => model.Description, "", new { @class = "text-danger small" })
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 py-2 rounded-pill">
                        <i class="bi bi-save me-1"></i> Update Book
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary px-4 py-2 rounded-pill">
                        Cancel
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            // Preview selected image
            $("#coverImageFile").change(function () {
                var input = this;
                if (input.files && input.files[0]) {
                    var reader = new FileReader();
                    reader.onload = function (e) {
                        $('#coverPreview').attr('src', e.target.result).removeClass('d-none');
                        $('#coverPlaceholderIcon').addClass('d-none');
                    }
                    reader.readAsDataURL(input.files[0]);
                }
            });
        });
    </script>
}
