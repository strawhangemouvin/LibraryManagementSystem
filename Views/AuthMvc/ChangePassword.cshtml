@using LibraryManagementSystem.Helpers
@using LibraryManagementSystem.Models.Entity
@{
    ViewBag.Title = "Change Password";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var user = ViewBag.User as User;
}

<div class="container-fluid py-4">
    <!-- Feedback Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 rounded-4 shadow-sm" style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.3);">
                <div class="card-header border-0 bg-transparent pt-4 px-4 pb-0">
                    <h4 style="font-family: 'Playfair Display', serif; font-weight: 800; color: #4A2E35;" class="mb-0">
                        <i class="bi bi-shield-lock-fill me-2" style="color: var(--primary-rose);"></i>Change Password
                    </h4>
                    <p class="text-muted mb-0" style="font-size: 13px;">Securely update your password below.</p>
                    <hr class="mt-3 mb-0" style="opacity: 0.15;" />
                </div>

                <div class="card-body p-4">
                    @using (Html.BeginForm("ChangePassword", "AuthMvc", FormMethod.Post))
                    {
                        <div class="d-flex flex-column gap-3">
                            <div>
                                <label class="form-label font-weight-bold" style="font-weight: 600;">Current Password</label>
                                <input type="password" name="oldPassword" required class="form-control" placeholder="Enter old password" />
                            </div>

                            <div>
                                <label class="form-label font-weight-bold" style="font-weight: 600;">New Password</label>
                                <input type="password" name="newPassword" required class="form-control" placeholder="Enter new password" />
                                <small class="text-muted d-block mt-1" style="font-size: 11px;">
                                    Password must be 6-15 characters and contain only lowercase letters and numbers.
                                </small>
                            </div>

                            <div>
                                <label class="form-label font-weight-bold" style="font-weight: 600;">Confirm New Password</label>
                                <input type="password" name="confirmNewPassword" required class="form-control" placeholder="Confirm new password" />
                            </div>

                            <div class="mt-4 d-flex justify-content-between">
                                <a href="@Url.Action("Profile", "AuthMvc")" class="btn btn-outline-secondary rounded-pill px-4">
                                    <i class="bi bi-x-circle me-1"></i> Cancel
                                </a>
                                <button type="submit" class="btn btn-main rounded-pill px-4">
                                    <i class="bi bi-key-fill me-1"></i> Update Password
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
