@model LibraryManagementSystem.Models.ViewModel.LoginRequest

@{
    ViewBag.Title = "Sign In";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center align-items-center" style="min-height: 68vh;">
    <div class="col-md-5 col-lg-4">
        <div class="text-center mb-4">
            <div style="font-size:58px;">🌙</div>
            <h2 style="color:#7B4F2C; font-weight:800;">Sign In</h2>
            <p class="text-muted">Masuk ke akun Moon Books kamu.</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        @using (Html.BeginForm("Login", "AuthMvc", FormMethod.Post))
        {
            <div class="mb-3">
                <label class="form-label">Username</label>
                @Html.TextBoxFor(m => m.Username, new { @class = "form-control", placeholder = "Masukkan username" })
                @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger small" })
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Masukkan password" })
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Sign In
            </button>
        }

        <div class="text-center mt-3">
            <small class="text-muted">Belum punya akun?</small>
            <a href="@Url.Action("Register", "AuthMvc")" style="color:#7B4F2C; font-weight:600;">
                Sign Up
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
