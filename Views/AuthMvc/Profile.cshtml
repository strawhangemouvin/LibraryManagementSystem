@using LibraryManagementSystem.Helpers
@using LibraryManagementSystem.Models.Entity
@{
    ViewBag.Title = "My Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var user = ViewBag.User as User;
    var member = ViewBag.Member as Member;

    string email = user?.Email ?? "";
    string avatarUrl = AvatarHelper.GetUserAvatarUrl(user?.Username ?? "", email, 150);
}

<div class="container-fluid py-4">
    <!-- Feedback Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Left Column: Photo, Name, and Main Action Links -->
        <div class="col-lg-4">
            <div class="card border-0 rounded-4 shadow-sm h-100" style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.3);">
                <div class="card-body p-4 text-center d-flex flex-column justify-content-between h-100" style="min-height: 480px;">
                    <div>
                        <!-- Profile Photo Box -->
                        <div class="position-relative d-inline-block mb-3">
                            <img src="@avatarUrl" alt="Avatar" class="rounded-circle border border-3 border-white shadow-sm" style="width: 140px; height: 140px; object-fit: cover;" />
                            <span class="position-absolute bottom-0 end-0 p-2 bg-success border border-3 border-white rounded-circle" title="Active"></span>
                        </div>

                        <!-- Name, Username, Role Info Box -->
                        <h4 class="mb-1" style="font-family: 'Playfair Display', serif; font-weight: 800; color: #4A2E35;">@user.FullName</h4>
                        <p class="text-muted mb-2">@@@user.Username</p>
                        <span class="badge rounded-pill mb-4 px-3 py-1" style="background: var(--primary-rose); color: white; font-weight: 600;">@user.Role</span>

                        <hr class="my-4" style="opacity: 0.15;" />

                        <!-- Edit Profile & Change Password Links -->
                        <div class="d-flex flex-column gap-2">
                            <a href="@Url.Action("EditProfile", "AuthMvc")" class="btn btn-main rounded-pill w-100 py-2">
                                <i class="bi bi-pencil-square me-1"></i> Edit Profile
                            </a>
                            <a href="@Url.Action("ChangePassword", "AuthMvc")" class="btn btn-outline-secondary rounded-pill w-100 py-2">
                                <i class="bi bi-shield-lock me-1"></i> Change Password
                            </a>
                        </div>
                    </div>

                    <!-- Back to Dashboard -->
                    <div>
                        <hr class="my-4" style="opacity: 0.15;" />
                        @{
                            string dashboardAction = user.Role == "Librarian" ? "Librarian" : "Member";
                        }
                        <a href="@Url.Action(dashboardAction, "DashboardMvc")" class="btn btn-light rounded-pill w-100 py-2 text-muted" style="border: 1px solid rgba(0,0,0,0.05);">
                            <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Owner Information Details -->
        <div class="col-lg-8">
            <div class="card border-0 rounded-4 shadow-sm h-100" style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.3);">
                <div class="card-header border-0 bg-transparent pt-4 px-4 pb-0">
                    <h5 style="font-family: 'Playfair Display', serif; font-weight: 800; color: #4A2E35;" class="mb-0">
                        <i class="bi bi-info-circle-fill me-2" style="color: var(--primary-rose);"></i>Account Information
                    </h5>
                    <p class="text-muted mb-0" style="font-size: 13px;">Overview of the account owner's registration and status details.</p>
                    <hr class="mt-3 mb-0" style="opacity: 0.15;" />
                </div>

                <div class="card-body p-4">
                    <div class="d-flex flex-column gap-3" style="font-size: 14.5px;">
                        <div class="row border-bottom pb-3 g-2 align-items-center" style="border-color: rgba(201, 122, 126, 0.1) !important;">
                            <div class="col-sm-3 text-muted">Username</div>
                            <div class="col-sm-9 fw-bold" style="color: #4A2E35;">@user.Username</div>
                        </div>

                        <div class="row border-bottom pb-3 g-2 align-items-center" style="border-color: rgba(201, 122, 126, 0.1) !important;">
                            <div class="col-sm-3 text-muted">Full Name</div>
                            <div class="col-sm-9 fw-bold" style="color: #4A2E35;">@user.FullName</div>
                        </div>

                        <div class="row border-bottom pb-3 g-2 align-items-center" style="border-color: rgba(201, 122, 126, 0.1) !important;">
                            <div class="col-sm-3 text-muted">Email Address</div>
                            <div class="col-sm-9 fw-bold" style="color: #4A2E35;">@user.Email</div>
                        </div>

                        <div class="row border-bottom pb-3 g-2 align-items-center" style="border-color: rgba(201, 122, 126, 0.1) !important;">
                            <div class="col-sm-3 text-muted">User Role</div>
                            <div class="col-sm-9 fw-bold text-uppercase text-monospace" style="color: #4A2E35; font-size: 13px;">@user.Role</div>
                        </div>

                        <div class="row border-bottom pb-3 g-2 align-items-center" style="border-color: rgba(201, 122, 126, 0.1) !important;">
                            <div class="col-sm-3 text-muted">Registration Date</div>
                            <div class="col-sm-9 fw-bold" style="color: #4A2E35;">@user.CreatedAt.ToString("dd MMMM yyyy, HH:mm")</div>
                        </div>

                        @if (member != null)
                        {
                            <div class="row border-bottom pb-3 g-2 align-items-center" style="border-color: rgba(201, 122, 126, 0.1) !important;">
                                <div class="col-sm-3 text-muted">Member Code</div>
                                <div class="col-sm-9 fw-bold text-monospace" style="color: var(--primary-rose);">@member.MemberCode</div>
                            </div>

                            <div class="row border-bottom pb-3 g-2 align-items-center" style="border-color: rgba(201, 122, 126, 0.1) !important;">
                                <div class="col-sm-3 text-muted">Class / Section</div>
                                <div class="col-sm-9 fw-bold" style="color: #4A2E35;">@(string.IsNullOrWhiteSpace(member.ClassName) ? "N/A" : member.ClassName)</div>
                            </div>

                            <div class="row border-bottom pb-3 g-2 align-items-start" style="border-color: rgba(201, 122, 126, 0.1) !important;">
                                <div class="col-sm-3 text-muted">Home Address</div>
                                <div class="col-sm-9 fw-bold text-start" style="color: #4A2E35; line-height: 1.6;">@(string.IsNullOrWhiteSpace(member.Address) ? "N/A" : member.Address)</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
