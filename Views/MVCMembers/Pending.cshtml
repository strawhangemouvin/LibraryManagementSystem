@model IEnumerable<LibraryManagementSystem.Models.ViewModel.MemberViewModel>

@{
    ViewBag.Title = "Pending Approvals";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0 rounded-4" style="background: rgba(255, 255, 255, 0.45); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.25);">
        <div class="card-header border-0 rounded-top-4" style="background-color: var(--primary-rose); color: white; padding: 20px;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-0" style="font-family: 'Playfair Display', serif; font-weight: 700;">Pending Registrations</h4>
                    <p class="mb-0 opacity-75" style="font-size: 13px;">List of library members waiting for librarian approval.</p>
                </div>

                <a href="@Url.Action("Index", "MVCMembers")" class="btn btn-sm btn-light rounded-pill px-3" style="color: var(--primary-rose); font-weight: 600;">
                    <i class="bi bi-people-fill me-1"></i> Back to Members
                </a>
            </div>
        </div>

        <div class="card-body p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success rounded-3">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger rounded-3">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                </div>
            }

            <div class="table-responsive rounded-4 border border-light">
                <table class="table table-hover align-middle mb-0 paginated-table" data-page-size="5">
                    <thead style="background-color: rgba(201, 122, 126, 0.1); border-bottom: 2px solid rgba(201, 122, 126, 0.15);">
                        <tr>
                            <th class="ps-3" style="width: 80px; color: #4A2E35;">No</th>
                            <th style="color: #4A2E35;">Full Name</th>
                            <th style="color: #4A2E35;">Member Code</th>
                            <th style="color: #4A2E35;">Email</th>
                            <th style="color: #4A2E35;">Class</th>
                            <th style="color: #4A2E35;">Status</th>
                            <th class="pe-3 text-end" style="width: 200px; color: #4A2E35;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            var no = 1;
                        }

                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3" style="font-weight: 600;">@no</td>
                                <td style="font-weight: 600; color: #4A2E35;">@item.FullName</td>
                                <td>
                                    <code class="text-dark" style="font-weight: 700;">@item.MemberCode</code>
                                </td>
                                <td>@item.Email</td>
                                <td>@(string.IsNullOrWhiteSpace(item.ClassName) ? "-" : item.ClassName)</td>
                                <td>
                                    <span class="badge bg-warning text-dark rounded-pill px-3 py-1">Pending</span>
                                </td>
                                <td class="pe-3 text-end">
                                    <div class="d-inline-flex gap-1">
                                        <a href="@Url.Action("Approve", "MVCMembers", new { id = item.Id })"
                                           class="btn btn-sm btn-outline-success" title="Approve"
                                           style="border-radius: 8px; height: 34px; display: inline-flex; align-items: center; gap: 4px; font-weight: 600; padding: 0 10px;"
                                           onclick="return confirm('Approve this member registration?');">
                                            <i class="bi bi-check-lg"></i> Approve
                                        </a>

                                        <a href="@Url.Action("Reject", "MVCMembers", new { id = item.Id })"
                                           class="btn btn-sm btn-outline-danger" title="Reject"
                                           style="border-radius: 8px; height: 34px; display: inline-flex; align-items: center; gap: 4px; font-weight: 600; padding: 0 10px;"
                                           onclick="return confirm('Reject this member registration?');">
                                            <i class="bi bi-x-lg"></i> Reject
                                        </a>
                                    </div>
                                </td>
                            </tr>

                            no++;
                        }

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox-fill d-block fs-3 mb-2 opacity-50"></i>
                                    No pending registrations found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>