
@model IEnumerable<LibraryManagementSystem.Models.ViewModel.MemberViewModel>

@{
    ViewBag.Title = "Data Member";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header border-0 rounded-top-4" style="background-color:#F7D9E3;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-0" style="color:#7A4E60;">Data Member</h4>
                    <small class="text-muted">Daftar seluruh member yang terdaftar di sistem perpustakaan.</small>
                </div>

                <a href="@Url.Action("Pending", "MVCMembers")" class="btn btn-sm btn-light rounded-pill">
                    Lihat Pending Member
                </a>
            </div>
        </div>

        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success rounded-3">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger rounded-3">
                    @TempData["Error"]
                </div>
            }

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead style="background-color:#FDF6F0;">
                        <tr>
                            <th>No</th>
                            <th>Nama Lengkap</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Kode Member</th>
                            <th>Alamat</th>
                            <th>Kelas</th>
                            <th>Status</th>
                            <th>Disetujui Oleh</th>
                            <th>Tanggal Approval</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            var no = 1;
                        }

                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@no</td>
                                <td>@item.FullName</td>
                                <td>@item.Username</td>
                                <td>@item.Email</td>
                                <td>@item.MemberCode</td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(item.Address))
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                    else
                                    {
                                        @item.Address
                                    }
                                </td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(item.ClassName))
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                    else
                                    {
                                        @item.ClassName
                                    }
                                </td>
                                <td>
                                    @if (item.Status == "Active")
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else if (item.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else if (item.Status == "Rejected")
                                    {
                                        <span class="badge bg-danger">Rejected</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                </td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(item.ApprovedByName))
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                    else
                                    {
                                        @item.ApprovedByName
                                    }
                                </td>
                                <td>
                                    @if (item.ApprovedAt == null)
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                    else
                                    {
                                        @item.ApprovedAt.Value.ToString("dd-MM-yyyy HH:mm")
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("Details", "MVCMembers", new { id = item.Id })"
                                       class="btn btn-sm btn-outline-secondary rounded-pill">
                                        Detail
                                    </a>
                                </td>
                            </tr>

                            no++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
