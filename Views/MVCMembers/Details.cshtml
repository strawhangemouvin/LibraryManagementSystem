@using LibraryManagementSystem.Helpers
@model LibraryManagementSystem.Models.ViewModel.MemberViewModel

@{
    ViewBag.Title = "Member Details";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string avatarUrl = AvatarHelper.GetUserAvatarUrl(Model.Username ?? "", Model.Email ?? "", 150);
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0 rounded-4" style="background: rgba(255, 255, 255, 0.45); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.25);">
        <div class="card-header border-0 rounded-top-4" style="background-color: var(--primary-rose); color: white; padding: 20px;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-0" style="font-family: 'Playfair Display', serif; font-weight: 700;">Member Profile</h4>
                    <p class="mb-0 opacity-75" style="font-size: 13px;">Complete account and membership profile details.</p>
                </div>
                <a href="@Url.Action("Index", "MVCMembers")" class="btn btn-sm btn-light rounded-pill px-3" style="color: var(--primary-rose); font-weight: 600;">
                    <i class="bi bi-arrow-left me-1"></i> Back to List
                </a>
            </div>
        </div>

        <div class="card-body p-4">
            <div class="row g-4">
                <!-- Left Column: Avatar -->
                <div class="col-lg-3 col-md-4">
                    <div class="p-4 rounded-4 bg-white bg-opacity-50 border border-white shadow-sm d-flex flex-column align-items-center text-center" style="min-height: 320px;">
                        <div class="position-relative d-inline-block mb-3">
                            <img src="@avatarUrl" alt="@Model.FullName Avatar" class="rounded-circle border border-3 border-white shadow-sm" style="width: 140px; height: 140px; object-fit: cover;" />
                            @if (Model.Status == "Active")
                            {
                                <span class="position-absolute bottom-0 end-0 p-2 bg-success border border-3 border-white rounded-circle" title="Active"></span>
                            }
                            else if (Model.Status == "Pending")
                            {
                                <span class="position-absolute bottom-0 end-0 p-2 bg-warning border border-3 border-white rounded-circle" title="Pending"></span>
                            }
                            else
                            {
                                <span class="position-absolute bottom-0 end-0 p-2 bg-danger border border-3 border-white rounded-circle" title="@Model.Status"></span>
                            }
                        </div>
                        <h5 class="mb-1 fw-bold" style="color: #4A2E35;">@Model.FullName</h5>
                        <p class="text-muted small mb-3">@@@Model.Username</p>
                        <span class="badge rounded-pill px-3 py-1" style="background: var(--primary-rose); color: white; font-weight: 600;">Member</span>
                    </div>
                </div>

                <!-- Right Column: Member Details -->
                <div class="col-lg-9 col-md-8">
                    <dl class="dl-horizontal" style="margin: 0 !important; max-width: 100% !important; border: 1px solid rgba(201, 122, 126, 0.15); padding: 25px; border-radius: 20px; background: rgba(255, 255, 255, 0.3);">
                        <dt>Full Name</dt>
                        <dd>@(string.IsNullOrWhiteSpace(Model.FullName) ? "-" : Model.FullName)</dd>

                        <dt>Username</dt>
                        <dd>@(string.IsNullOrWhiteSpace(Model.Username) ? "-" : Model.Username)</dd>

                        <dt>Member Code</dt>
                        <dd><code class="text-dark" style="font-weight: 700;">@Model.MemberCode</code></dd>

                        <dt>Email</dt>
                        <dd>@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</dd>

                        <dt>Address</dt>
                        <dd>@(string.IsNullOrWhiteSpace(Model.Address) ? "-" : Model.Address)</dd>

                        <dt>Class</dt>
                        <dd>@(string.IsNullOrWhiteSpace(Model.ClassName) ? "-" : Model.ClassName)</dd>

                        <dt>Status</dt>
                        <dd>
                            @if (Model.Status == "Active")
                            {
                                <span class="badge bg-success rounded-pill px-3">Active</span>
                            }
                            else if (Model.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark rounded-pill px-3">Pending</span>
                            }
                            else if (Model.Status == "Rejected")
                            {
                                <span class="badge bg-danger rounded-pill px-3">Rejected</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill px-3">@(string.IsNullOrWhiteSpace(Model.Status) ? "-" : Model.Status)</span>
                            }
                        </dd>

                        <dt>Approved By</dt>
                        <dd>@(string.IsNullOrWhiteSpace(Model.ApprovedByName) ? "-" : Model.ApprovedByName)</dd>

                        <dt>Approval Date</dt>
                        <dd>@(Model.ApprovedAt == null ? "-" : Model.ApprovedAt.Value.ToString("dd-MM-yyyy HH:mm"))</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>
