@{
    ViewBag.Title = "Dashboard Pustakawan";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header rounded-top-4" style="background-color:#F7D9E3;">
            <h4 class="mb-0" style="color:#7A4E60;">Dashboard Pustakawan</h4>
            <small class="text-muted">Halaman utama pustakawan untuk mengelola sistem perpustakaan.</small>
        </div>

        <div class="card-body">
            <h5>Selamat datang, @Session["FullName"]</h5>
            <p class="text-muted">
                Dari halaman ini pustakawan dapat menyetujui member, mengelola buku, kategori, peminjaman, laporan, dan activity log.
            </p>

            <hr />

            <div class="row">
                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body text-center">
                            <h6>Data Member</h6>
                            <a href="@Url.Action("Index", "MVCMembers")" class="btn btn-sm btn-primary rounded-pill mt-2">
                                Buka
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body text-center">
                            <h6>Pending Member</h6>
                            <a href="@Url.Action("Pending", "MVCMembers")" class="btn btn-sm btn-warning rounded-pill mt-2">
                                Approve
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body text-center">
                            <h6>Kelola Buku</h6>
                            <a href="@Url.Action("Index", "MVCBooks")" class="btn btn-sm btn-outline-secondary rounded-pill mt-2">
                                Buka
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body text-center">
                            <h6>Kelola Kategori</h6>
                            <a href="@Url.Action("Index", "MVCCategories")" class="btn btn-sm btn-outline-secondary rounded-pill mt-2">
                                Buka
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <a href="@Url.Action("Index", "MVCBorrowings")" class="btn btn-outline-secondary rounded-pill">
                    Data Peminjaman
                </a>

                <a href="@Url.Action("Index", "ReportsMVC")" class="btn btn-outline-secondary rounded-pill">
                    Laporan
                </a>

                <a href="@Url.Action("Index", "ActivityLogsMVC")" class="btn btn-outline-secondary rounded-pill">
                    Activity Log
                </a>

                <a href="@Url.Action("Logout", "AuthMvc")" class="btn btn-danger rounded-pill">
                    Logout
                </a>
            </div>
        </div>
    </div>
</div>