@model IEnumerable<LibraryManagementSystem.Models.Entity.Category>

@{
    ViewBag.Title = "Categories";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0 rounded-4" style="background: rgba(255, 255, 255, 0.45); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.25);">
        <div class="card-header border-0 rounded-top-4" style="background-color: var(--primary-rose) !important; color: var(--text-dark); padding: 20px;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-0" style="font-family: 'Playfair Display', serif; font-weight: 700; color: var(--text-dark) !important;">Manage Categories</h4>
                    <p class="mb-0 text-muted" style="font-size: 13px; color: var(--text-dark) !important; opacity: 0.85;">Manage library book genres and categories.</p>
                </div>

                <a href="@Url.Action("Create", "MVCCategories")" class="btn btn-sm btn-light rounded-pill px-3" style="color: var(--primary-rose); font-weight: 600;">
                    <i class="bi bi-plus-lg me-1"></i> Add Category
                </a>
            </div>
        </div>

        <div class="card-body p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success rounded-3 alert-dismissible fade show" role="alert" style="font-size: 14px;">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger rounded-3 alert-dismissible fade show" role="alert" style="font-size: 14px;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="table-responsive rounded-4 border border-light">
                <table class="table table-hover align-middle mb-0 paginated-table" data-page-size="5">
                    <thead style="background-color: rgba(201, 122, 126, 0.1); border-bottom: 2px solid rgba(201, 122, 126, 0.15);">
                        <tr>
                            <th class="ps-3" style="width: 80px; color: #4A2E35;">No</th>
                            <th style="color: #4A2E35;">Category Name</th>
                            <th style="color: #4A2E35;">Description</th>
                            <th class="pe-3 text-end" style="width: 150px; color: #4A2E35;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            var no = 1;
                        }
                        @foreach (var item in Model) {
                            <tr>
                                <td class="ps-3" style="font-weight: 600;">@no</td>
                                <td style="font-weight: 600; color: #4A2E35;">@item.CategoryName</td>
                                <td class="text-muted">@(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)</td>
                                <td class="pe-3 text-end">
                                    <div class="d-inline-flex gap-1">
                                        <a href="@Url.Action("Details", "MVCCategories", new { id = item.Id })" 
                                           class="btn btn-sm btn-outline-secondary" title="View Details"
                                           style="border-radius: 8px; width: 34px; height: 34px; display: inline-flex; align-items: center; justify-content: center; padding: 0;">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", "MVCCategories", new { id = item.Id })" 
                                           class="btn btn-sm btn-outline-primary" title="Edit Category"
                                           style="border-radius: 8px; width: 34px; height: 34px; display: inline-flex; align-items: center; justify-content: center; padding: 0;">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger delete-btn" 
                                                data-id="@item.Id" data-name="@item.CategoryName" title="Delete Category"
                                                style="border-radius: 8px; width: 34px; height: 34px; display: inline-flex; align-items: center; justify-content: center; padding: 0;">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            no++;
                        }
                        @if (!Model.Any()) {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox-fill d-block fs-3 mb-2 opacity-50"></i>
                                    No categories available.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                <a href="@Url.Action("Librarian", "DashboardMvc")" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>

<!-- DELETE CONFIRMATION MODAL -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(15px);">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title font-weight-bold" id="deleteConfirmModalLabel" style="color: var(--text-dark); font-family: 'Playfair Display', serif; font-weight: 700;">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-3">
                <p class="mb-2">Are you sure you want to delete category <strong id="deleteItemName" style="color: var(--text-dark);"></strong>?</p>
                <small class="text-danger"><i class="bi bi-exclamation-triangle-fill me-1"></i>This action will remove the category. Books under this category may become uncategorized.</small>
            </div>
            <div class="modal-footer border-top-0 d-flex justify-content-end gap-2">
                @using (Html.BeginForm("Delete", "MVCCategories", FormMethod.Post, new { id = "deleteForm", @class = "m-0" }))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteItemId" value="" />
                    <button type="submit" class="btn btn-danger rounded-pill px-4">Delete</button>
                }
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Inline Delete Modal Trigger
            $('.delete-btn').click(function(e) {
                e.preventDefault();
                var id = $(this).data('id');
                var name = $(this).data('name');
                
                $('#deleteItemId').val(id);
                $('#deleteItemName').text(name);
                
                var deleteModal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
                deleteModal.show();
            });
        });
    </script>
}
