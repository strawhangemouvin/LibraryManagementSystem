@using LibraryManagementSystem.Helpers
@using LibraryManagementSystem.Services.Context
@using LibraryManagementSystem.Models.Entity
@using System.Data.Entity
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    bool isAuthPage = currentController.Equals("AuthMvc", StringComparison.OrdinalIgnoreCase) &&
                     (currentAction.Equals("Login", StringComparison.OrdinalIgnoreCase) ||
                      currentAction.Equals("Register", StringComparison.OrdinalIgnoreCase) ||
                      currentAction.Equals("ForgotPassword", StringComparison.OrdinalIgnoreCase) ||
                      currentAction.Equals("ResetPassword", StringComparison.OrdinalIgnoreCase));

    // Fallback berdasarkan ViewBag.Title
    if (!isAuthPage && ViewBag.Title != null)
    {
        string pageTitle = ViewBag.Title.ToString();
        if (pageTitle.Equals("Sign In", StringComparison.OrdinalIgnoreCase) ||
            pageTitle.Equals("Sign Up", StringComparison.OrdinalIgnoreCase) ||
            pageTitle.Equals("Forgot Password", StringComparison.OrdinalIgnoreCase) ||
            pageTitle.Equals("Reset Password", StringComparison.OrdinalIgnoreCase))
        {
            isAuthPage = true;
        }
    }

    string email = Session["Email"]?.ToString();
    List<string> notifications = new List<string>();
    int pendingApprovalsCount = 0;
    int pendingRequestsCount = 0;
    int overdueCount = 0;
    int dueSoonCount = 0;

    if (Session["UserId"] != null)
    {
        int userId = (int)Session["UserId"];
        string role = Session["Role"]?.ToString();

        using (var db = new LibraryDbContext())
        {
            if (string.IsNullOrEmpty(email))
            {
                var user = db.Users.Find(userId);
                if (user != null)
                {
                    email = user.Email;
                    Session["Email"] = email;
                }
            }

            if (role == "Librarian")
            {
                pendingApprovalsCount = db.Users.Count(u => u.Status == "Pending" && u.Role == "Member");
                if (pendingApprovalsCount > 0)
                {
                    notifications.Add($"There are {pendingApprovalsCount} member registration(s) pending approval.");
                }

                pendingRequestsCount = db.Borrowings.Count(b => b.Status == "Requested");
                if (pendingRequestsCount > 0)
                {
                    notifications.Add($"There are {pendingRequestsCount} borrowing request(s) waiting for approval.");
                }
            }
            else if (role == "Member")
            {
                var member = db.Members.FirstOrDefault(m => m.UserId == userId);
                if (member != null)
                {
                    int memberId = member.Id;
                    DateTime today = DateTime.Today;
                    DateTime threeDaysFromNow = today.AddDays(3);

                    var overdueBorrowings = db.Borrowings
                        .Where(b => b.MemberId == memberId && b.Status == "Borrowed" && b.DueDate < today)
                        .Include(b => b.Book)
                        .ToList();
                    overdueCount = overdueBorrowings.Count;
                    foreach (var ob in overdueBorrowings)
                    {
                        var daysLate = (today - ob.DueDate.Value).Days;
                        notifications.Add($"OVERDUE: '{ob.Book.Title}' is overdue by {daysLate} day(s). Please return it immediately.");
                    }

                    var dueSoonBorrowings = db.Borrowings
                        .Where(b => b.MemberId == memberId && b.Status == "Borrowed" && b.DueDate >= today && b.DueDate <= threeDaysFromNow)
                        .Include(b => b.Book)
                        .ToList();
                    dueSoonCount = dueSoonBorrowings.Count;
                    foreach (var dbb in dueSoonBorrowings)
                    {
                        var daysLeft = (dbb.DueDate.Value - today).Days;
                        string dayWord = daysLeft == 0 ? "today" : $"in {daysLeft} day(s)";
                        notifications.Add($"DUE SOON: '{dbb.Book.Title}' is due {dayWord}.");
                    }
                }
            }
        }
    }

    var avatarUrl = AvatarHelper.GetUserAvatarUrl(Session["Username"]?.ToString() ?? "", email ?? "", 80);
    int totalNotifications = notifications.Count;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Moon Books</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        :root {
            --primary-rose: #C97A7E;
            --primary-rose-hover: #B56B6B;
            --secondary-peach: #FFD5C2;
            --accent-gold: #E6C587;
            --text-dark: #3A1F24;
            --text-muted: #7E6569;
            --bg-gradient: linear-gradient(135deg, #FFF0F2 0%, #FFFDF8 50%, #F6EFFF 100%);
            --glass-bg: rgba(255, 255, 255, 0.65);
            --glass-border: rgba(255, 255, 255, 0.5);
            --shadow-soft: 0 16px 36px rgba(201, 122, 126, 0.08);
            --shadow-hover: 0 24px 48px rgba(201, 122, 126, 0.16);
            --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        /* --- UI BADGES & BUTTONS --- */
        .badge.rounded-pill { padding: 6px 14px !important; font-weight: 600 !important; letter-spacing: 0.3px; border-radius: 30px !important; }
        .badge.bg-success { background-color: #E8F8F5 !important; color: #117A65 !important; border: 1px solid #D1F2EB !important; }
        .badge.bg-warning { background-color: #FEF9E7 !important; color: #B7950B !important; border: 1px solid #FCEFCE !important; }
        .badge.bg-danger { background-color: #FDEDEC !important; color: #C0392B !important; border: 1px solid #FADBD8 !important; }
        .badge.bg-secondary { background-color: #F2F4F4 !important; color: #7F8C8D !important; border: 1px solid #E5E7E9 !important; }
        .badge.bg-primary { background-color: #EAF2F1 !important; color: #117A65 !important; border: 1px solid #D1F2EB !important; }
        .badge.bg-info { background-color: #F5EEF8 !important; color: #8E44AD !important; border: 1px solid #EBDEF0 !important; }

        .btn-success.rounded-pill { background-color: #E8F8F5 !important; border: 1.5px solid #A3E4D7 !important; color: #117A65 !important; font-weight: 700; transition: var(--transition-smooth); }
        .btn-success.rounded-pill:hover { background-color: #A3E4D7 !important; color: #117A65 !important; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(163, 228, 215, 0.4); }
        .btn-danger.rounded-pill { background-color: #FDEDEC !important; border: 1.5px solid #FADBD8 !important; color: #C0392B !important; font-weight: 700; transition: var(--transition-smooth); }
        .btn-danger.rounded-pill:hover { background-color: #FADBD8 !important; color: #C0392B !important; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(250, 219, 216, 0.4); }
        .btn-main, .btn-primary { background: linear-gradient(135deg, var(--primary-rose) 0%, #E5989B 100%) !important; border: none !important; color: white !important; font-weight: 700; transition: var(--transition-smooth); }
        .btn-main:hover, .btn-primary:hover { background: linear-gradient(135deg, var(--primary-rose-hover) 0%, var(--primary-rose) 100%) !important; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(201, 122, 126, 0.35); }
        .btn-secondary.rounded-pill { background-color: #F2F4F4 !important; border: 1.5px solid #E5E7E9 !important; color: #7F8C8D !important; font-weight: 700; transition: var(--transition-smooth); }
        .btn-secondary.rounded-pill:hover { background-color: #E5E7E9 !important; color: #7F8C8D !important; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(229, 231, 233, 0.4); }
        .btn-info.rounded-pill { background-color: #F5EEF8 !important; border: 1.5px solid #EBDEF0 !important; color: #8E44AD !important; font-weight: 700; transition: var(--transition-smooth); }
        .btn-info.rounded-pill:hover { background-color: #EBDEF0 !important; color: #8E44AD !important; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(235, 222, 240, 0.4); }
        .btn-outline-danger.rounded-pill { border: 1.5px solid #FADBD8 !important; color: #C0392B !important; background: transparent !important; font-weight: 700; transition: var(--transition-smooth); }
        .btn-outline-danger.rounded-pill:hover { background-color: #FDEDEC !important; transform: translateY(-2px); }

        /* Full-screen Edge-to-edge Auth Pages */
        .auth-container-fluid { width: 100%; min-height: 100vh; margin: 0 !important; padding: 0 !important; overflow-x: hidden; background: #FFFDF8; }
        .auth-page-shell { width: 100%; height: 100%; margin: 0 !important; padding: 0 !important; }

        html, body { margin: 0; min-height: 100vh; font-family: 'Plus Jakarta Sans', Arial, sans-serif; background: var(--bg-gradient); color: var(--text-dark); }

        /* --- LAYOUT PORTAL & PUBLIC --- */
        .moon-navbar { background: rgba(255, 245, 245, 0.8); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255, 255, 255, 0.4); box-shadow: 0 4px 30px rgba(0, 0, 0, 0.02); padding: 16px 40px; position: sticky; top: 0; z-index: 999; transition: var(--transition-smooth); }
        .moon-brand { font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 800; color: var(--text-dark) !important; text-decoration: none; display: flex; align-items: center; gap: 10px; letter-spacing: -0.5px; transition: var(--transition-smooth); }
        .moon-brand:hover { color: var(--primary-rose) !important; transform: translateY(-1px); }
        .moon-brand span { color: var(--primary-rose); }
        .moon-nav-link { font-size: 15px; color: var(--text-dark) !important; font-weight: 500; margin-left: 8px; border-radius: 24px; padding: 8px 18px !important; transition: var(--transition-smooth); }
        .moon-nav-link:hover { background-color: rgba(201, 122, 126, 0.1); color: var(--primary-rose) !important; }
        .moon-nav-link.active { background-color: rgba(201, 122, 126, 0.15) !important; color: var(--primary-rose) !important; font-weight: 700 !important; border: 1px solid rgba(201, 122, 126, 0.25) !important; }
        .btn-outline-primary.active-btn { background: linear-gradient(135deg, var(--primary-rose) 0%, #E5989B 100%) !important; color: white !important; border-color: transparent !important; box-shadow: 0 4px 15px rgba(201, 122, 126, 0.3) !important; }

        .moon-container { padding: 40px 60px 20px 60px; min-height: calc(100vh - 170px); }
        .moon-page-shell { background: var(--glass-bg); border: 1px solid var(--glass-border); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-radius: 28px; padding: 35px; box-shadow: var(--shadow-soft); }

        #wrapper { overflow: hidden; background: var(--bg-gradient); height: 100vh; display: flex; }
        .glass-sidebar { width: 280px; background: linear-gradient(180deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 240, 242, 0.8) 100%); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-right: 1px solid rgba(201, 122, 126, 0.15); display: flex; flex-direction: column; padding: 30px 20px; transition: margin 0.3s cubic-bezier(0.16, 1, 0.3, 1); height: 100vh; overflow-y: auto; flex-shrink: 0; }
        .sidebar-heading { margin-bottom: 25px; }
        .user-card-sidebar { display: flex; align-items: center; gap: 12px; background: rgba(201, 122, 126, 0.08); border: 1px solid rgba(201, 122, 126, 0.1); border-radius: 20px; padding: 12px 15px; margin-bottom: 25px; }
        .user-avatar-circle { width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, var(--primary-rose) 0%, #E5989B 100%); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 16px; box-shadow: 0 4px 10px rgba(201, 122, 126, 0.2); flex-shrink: 0; }
        .badge-role { font-size: 9px !important; padding: 4px 8px !important; background-color: var(--primary-rose) !important; color: white !important; border-radius: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; display: inline-block; margin-top: 4px; }

        .sidebar-nav-links { display: flex; flex-direction: column; gap: 6px; flex-grow: 1; }
        .sidebar-nav-links .list-group-item { border: none !important; background: transparent !important; color: var(--text-dark) !important; border-radius: 16px !important; padding: 12px 16px !important; font-weight: 600; display: flex; align-items: center; gap: 12px; font-size: 14px; transition: var(--transition-smooth); }
        .sidebar-nav-links .list-group-item i { font-size: 18px; color: var(--text-muted); transition: var(--transition-smooth); }
        .sidebar-nav-links .list-group-item:hover { background-color: rgba(201, 122, 126, 0.08) !important; color: var(--primary-rose) !important; transform: translateX(4px); }
        .sidebar-nav-links .list-group-item:hover i { color: var(--primary-rose); }
        .sidebar-nav-links .list-group-item.active { background: linear-gradient(135deg, var(--primary-rose) 0%, #E5989B 100%) !important; color: white !important; box-shadow: 0 8px 166px rgba(201, 122, 126, 0.18); }
        .sidebar-nav-links .list-group-item.active i { color: white; }
        .logout-link { color: #dc3545 !important; } .logout-link i { color: #dc3545 !important; }
        .logout-link:hover { background-color: rgba(220, 53, 69, 0.08) !important; color: #dc3545 !important; }

        #page-content-wrapper { min-width: 0; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
        .portal-topbar { height: 75px; background: linear-gradient(90deg, rgba(255, 255, 255, 0.85) 0%, rgba(255, 240, 242, 0.75) 100%); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid rgba(201, 122, 126, 0.12); display: flex; align-items: center; padding: 0 35px; justify-content: space-between; flex-shrink: 0; }
        .portal-container { padding: 35px; overflow-y: auto; flex-grow: 1; height: calc(100vh - 75px - 50px); }
        #wrapper.toggled #sidebar-wrapper { margin-left: -280px; }

        #sidebarToggle { width: 40px; height: 40px; border-radius: 50% !important; background: transparent; border: none; color: var(--text-dark); display: inline-flex; align-items: center; justify-content: center; transition: var(--transition-smooth); cursor: pointer; outline: none; }
        #sidebarToggle:hover { background-color: rgba(201, 122, 126, 0.15) !important; color: var(--primary-rose) !important; transform: scale(1.05); }
        #sidebarToggle i { font-size: 20px; }

        .portal-mini-footer { font-size: 13px; color: var(--text-muted); border-top: 1px solid rgba(201, 122, 126, 0.08); background: rgba(255, 255, 255, 0.3); text-align: center; padding: 15px 0; }

        /* Notification Drawer */
        .notification-drawer { position: fixed; top: 0; right: -350px; width: 350px; height: 100vh; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(25px); -webkit-backdrop-filter: blur(25px); border-left: 1px solid rgba(201, 122, 126, 0.2); box-shadow: -10px 0 30px rgba(74, 46, 53, 0.1); z-index: 1050; transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1); display: flex; flex-direction: column; padding: 30px 24px; }
        .notification-drawer.open { right: 0; }
        .notification-drawer-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(201, 122, 126, 0.15); padding-bottom: 15px; margin-bottom: 20px; }
        .notification-drawer-header h5 { font-family: 'Playfair Display', serif; font-weight: 800; color: var(--text-dark); margin: 0; }
        .notification-close-btn { background: transparent; border: none; color: var(--text-muted); font-size: 20px; cursor: pointer; transition: var(--transition-smooth); }
        .notification-close-btn:hover { color: var(--primary-rose); }
        .notification-drawer-body { flex-grow: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; }
        .notification-item { padding: 16px; border-radius: 18px; background: rgba(255, 255, 255, 0.6); border: 1px solid rgba(201, 122, 126, 0.1); font-size: 13.5px; line-height: 1.5; transition: var(--transition-smooth); }
        .notification-item:hover { background: rgba(255, 255, 255, 0.9); border-color: var(--primary-rose); transform: translateY(-1px); }
        .notification-item-overdue { border-left: 4px solid #dc3545 !important; background: rgba(220, 53, 69, 0.03); }
        .notification-item-warning { border-left: 4px solid var(--accent-gold) !important; background: rgba(230, 197, 135, 0.03); }
        .notification-item-info { border-left: 4px solid var(--primary-rose) !important; background: rgba(201, 122, 126, 0.03); }
        .notification-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(74, 46, 53, 0.15); backdrop-filter: blur(4px); z-index: 1040; display: none; opacity: 0; transition: opacity 0.4s ease; }
        .notification-overlay.show { display: block; opacity: 1; }

        /* Public Footer Elements */
        .moon-footer { margin-top: 50px; padding: 60px 60px 30px 60px; background: radial-gradient(circle at 10% 20%, #4A2E35 0%, #301A1E 100%); border-top: 1px solid rgba(255, 255, 255, 0.05); color: #F6EFFF; box-shadow: 0 -4px 30px rgba(0, 0, 0, 0.05); border-radius: 28px 28px 0 0; }
        .moon-footer-title { font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 800; margin-bottom: 12px; color: white; }
        .moon-footer-link { display: inline-block; text-decoration: none; color: #E5D9DC; margin-bottom: 10px; font-size: 14px; transition: var(--transition-smooth); }
        .moon-footer-link:hover { color: white; transform: translateY(-2px); }
        .moon-contact-icon { display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 50%; background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.1); color: #F6EFFF; font-size: 18px; text-decoration: none; transition: var(--transition-smooth); }
        .moon-contact-icon:hover { background: var(--primary-rose); border-color: var(--primary-rose); color: white; transform: translateY(-3px); box-shadow: 0 4px 12px rgba(201, 122, 126, 0.3); }
        .moon-footer-badge { display: inline-block; background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.1); color: #F6EFFF; padding: 6px 12px; border-radius: 18px; margin: 0 4px 8px 0; font-size: 13px; transition: var(--transition-smooth); }
        .moon-footer-badge:hover { background: var(--primary-rose); border-color: var(--primary-rose); transform: translateY(-2px); }
        .moon-footer-bottom { border-top: 1px solid rgba(255, 255, 255, 0.08); margin-top: 30px; padding-top: 18px; text-align: center; font-size: 14px; color: #E5D9DC; opacity: 0.7; }

        @@media (max-width: 992px) {
            .moon-navbar { padding: 16px 24px; }
            .moon-container { padding: 30px 24px 20px 24px; }
            .moon-page-shell { padding: 24px; }
            .moon-footer { padding: 40px 24px 20px 24px; }
            #sidebar-wrapper { margin-left: -280px; position: fixed; z-index: 1000; height: 100vh; box-shadow: 0 10px 30px rgba(74, 46, 53, 0.1); }
            #wrapper.toggled #sidebar-wrapper { margin-left: 0; }
            .portal-topbar { padding: 0 20px; }
            .portal-container { padding: 20px; }
        }
    </style>
</head>

<body>
    @if (Session["Role"] != null && !isAuthPage)
    {
        <div class="d-flex" id="wrapper">
            <!-- Sidebar -->
            <aside id="sidebar-wrapper" class="glass-sidebar">
                <div class="sidebar-heading">
                    @{
                        string brandUrl = Url.Action("Index", "HomeMvc");
                        if (Session["Role"] != null)
                        {
                            string userRole = Session["Role"].ToString();
                            brandUrl = userRole == "Librarian" ? Url.Action("Librarian", "DashboardMvc") : Url.Action("Member", "DashboardMvc");
                        }
                    }
                    <a class="moon-brand" href="@brandUrl">
                        <i class="bi bi-moon-stars-fill me-2" style="color: var(--primary-rose);"></i>Moon <span>Books</span>
                    </a>
                </div>

                <!-- User Profile Card -->
                <a href="@Url.Action("Profile", "AuthMvc")" class="text-decoration-none d-block">
                    <div class="user-card-sidebar">
                        <img src="@avatarUrl" alt="Avatar" class="rounded-circle" style="width: 44px; height: 44px; object-fit: cover; border: 2px solid var(--primary-rose);" />
                        <div class="user-info-text">
                            <h6 class="mb-0 text-truncate font-weight-bold" style="color: var(--text-dark); max-width: 170px;">@Session["FullName"]</h6>
                            <span class="badge badge-role">@Session["Role"]</span>
                        </div>
                    </div>
                </a>

                <!-- Nav Links -->
                <div class="sidebar-nav-links">
                    @if (Session["Role"].ToString() == "Librarian")
                    {
                        <a href="@Url.Action("Librarian", "DashboardMvc")" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["action"].ToString() == "Librarian" ? "active" : "")">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                        <a href="@Url.Action("Index", "MVCBooks")" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["controller"].ToString() == "MVCBooks" ? "active" : "")">
                            <i class="bi bi-book"></i> Books
                        </a>
                        <a href="@Url.Action("Index", "MVCMembers")" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["controller"].ToString() == "MVCMembers" ? "active" : "")">
                            <i class="bi bi-people"></i> Members
                        </a>
                        <a href="@Url.Action("Index", "MVCBorrowings")" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["controller"].ToString() == "MVCBorrowings" ? "active" : "")">
                            <i class="bi bi-arrow-left-right"></i> Borrowings
                        </a>
                        <a href="@Url.Action("Index", "ReportsMvc")" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["controller"].ToString() == "ReportsMvc" ? "active" : "")">
                            <i class="bi bi-bar-chart-line"></i> Reports
                        </a>
                    }
                    else if (Session["Role"].ToString() == "Member")
                    {
                        <a href="@Url.Action("Member", "DashboardMvc")" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["action"].ToString() == "Member" ? "active" : "")">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                        <a href="@Url.Action("Index", "MVCBooks")" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["controller"].ToString() == "MVCBooks" ? "active" : "")">
                            <i class="bi bi-book-half"></i> Book Catalog
                        </a>
                        <a href="@Url.Action("MyHistory", "MVCBorrowings")" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["action"].ToString() == "MyHistory" ? "active" : "")">
                            <i class="bi bi-clock-history"></i> Borrowing History
                        </a>
                    }
                    <a href="@Url.Action("Logout", "AuthMvc")" class="list-group-item list-group-item-action logout-link" onclick="return confirm('Are you sure you want to logout?');">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </aside>

            <!-- Page Content Wrapper -->
            <div id="page-content-wrapper" class="w-100 d-flex flex-column">
                <header class="portal-topbar">
                    <div class="d-flex align-items-center">
                        <button id="sidebarToggle" title="Toggle Sidebar">
                            <i class="bi bi-list"></i>
                        </button>
                        <h4 class="mb-0 font-weight-bold" style="color: var(--text-dark); font-family: 'Playfair Display', serif; font-weight: 800;">
                            @ViewBag.Title
                        </h4>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="position-relative cursor-pointer me-2" id="notificationBell" title="Notifications">
                            <i class="bi bi-bell fs-5 text-muted"></i>
                            @if (totalNotifications > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 8px; padding: 4px 6px;">
                                    @totalNotifications
                                </span>
                            }
                        </div>
                        <a href="@Url.Action("Profile", "AuthMvc")" class="d-flex align-items-center text-decoration-none">
                            <img src="@avatarUrl" alt="Avatar" class="rounded-circle" style="width: 32px; height: 32px; object-fit: cover; border: 1.5px solid var(--primary-rose);" />
                        </a>
                    </div>
                </header>

                <main class="portal-container flex-grow-1">
                    <div class="moon-page-shell">
                        @RenderBody()
                    </div>
                </main>

                <footer class="portal-mini-footer">
                    &copy; @DateTime.Now.Year Moon Books. Crafted with <i class="bi bi-heart-fill" style="color: var(--primary-rose); font-size: 11px;"></i> for a beautiful reading experience.
                </footer>
            </div>

            <div class="notification-overlay" id="notificationOverlay"></div>
            <div class="notification-drawer" id="notificationDrawer">
                <div class="notification-drawer-header">
                    <h5><i class="bi bi-bell-fill me-2" style="color: var(--primary-rose);"></i>Notifications</h5>
                    <button class="notification-close-btn" id="closeNotificationDrawer"><i class="bi bi-x-lg"></i></button>
                </div>
                <div class="notification-drawer-body">
                    @if (notifications.Count == 0)
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-bell-slash fs-1 d-block mb-3" style="opacity: 0.5;"></i>
                            <span>No new notifications</span>
                        </div>
                    }
                    else
                    {
                        foreach (var note in notifications)
                        {
                            string alertClass = "notification-item-info";
                            if (note.Contains("OVERDUE")) { alertClass = "notification-item-overdue"; }
                            else if (note.Contains("DUE SOON")) { alertClass = "notification-item-warning"; }
                            <div class="notification-item @alertClass">@note</div>
                        }
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        if (!isAuthPage)
        {
            <nav class="navbar navbar-expand-lg moon-navbar">
                <a class="navbar-brand moon-brand" href="@Url.Action("Index", "HomeMvc")">
                    <i class="bi bi-moon-stars-fill me-2" style="color: var(--primary-rose);"></i>Moon <span>Books</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#moonNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-end" id="moonNavbar">
                    <ul class="navbar-nav align-items-lg-center">
                        <li class="nav-item"><a class="nav-link moon-nav-link @(currentController == "HomeMvc" && currentAction == "Index" ? "active" : "")" href="@Url.Action("Index", "HomeMvc")">Home</a></li>
                        <li class="nav-item"><a class="nav-link moon-nav-link @(currentController == "AuthMvc" && currentAction == "Login" ? "active" : "")" href="@Url.Action("Login", "AuthMvc")">Sign In</a></li>
                        <li class="nav-item"><a class="btn btn-outline-primary ms-lg-2 @(currentController == "AuthMvc" && currentAction == "Register" ? "active-btn" : "")" href="@Url.Action("Register", "AuthMvc")" style="font-size: 15px;">Sign Up</a></li>
                    </ul>
                </div>
            </nav>
        }

        <main class="@(isAuthPage ? "auth-container-fluid" : "moon-container")">
            <div class="@(isAuthPage ? "auth-page-shell" : "moon-page-shell")">
                @RenderBody()
            </div>
        </main>
    }

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    <script>
        $(document).ready(function () {
            $("#sidebarToggle").click(function (e) { e.preventDefault(); $("#wrapper").toggleClass("toggled"); });
            $("#notificationBell, #closeNotificationDrawer, #notificationOverlay").click(function (e) { e.preventDefault(); $("#notificationDrawer").toggleClass("open"); $("#notificationOverlay").toggle().toggleClass("show"); });
        });
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>